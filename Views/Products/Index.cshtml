@using ClientPortal.Models
@model IEnumerable<ClientPortal.Models.ProductGroupVm>
@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
{
    <div class="alert" style="color:red;">@ViewBag.ErrorMessage</div>
}

@{
    ViewData["Title"] = "Products & Services";
    var q = ViewBag.Query as string;         // Search/filter query
    string[] classes = ViewBag.Classes as string[] ?? Array.Empty<string>(); // Grouping classes
}

<!-- Products and Services Page (renders live-fetched products grouped and filtered) -->

<section class="products-page">
    <div class="wrap">
        <h2>Products & Services</h2>

        <!-- Search and class filter form -->
        <form method="get" class="search-form">
            <input type="text" name="q" value="@q" placeholder="Search products…" class="form-control" />
            <select name="classFilter" class="form-select">
                <option value="">All Classes</option>
                @foreach (var c in classes)
                {
                    <option value="@c">@c</option>
                }
            </select>
            <button type="submit" class="btn-primary">Apply Filters</button>
        </form>

        <!-- If there are no products, show message -->
        @if (Model == null || !Model.Any())
        {
            <div class="alert">No products available.</div>
        }
        else
        {
            <!-- Loop through product groups and subgroups for display -->
            <div class="p-grid">
                @foreach (var g in Model)
                {
                    <section class="p-group">
                        <h3>@g.MainClass</h3>
                        @foreach (var sg in g.SubGroups)
                        {
                            <div class="p-sub">
                                <div class="p-subtle">@sg.SubClass</div>
                                <div class="p-cards">
                                    @foreach (var p in sg.Items)
                                    {
                                        var imgPath = $"/images/products/{p.ImageSlug}.jpg";
                                        <article class="p-card">
                                            <div class="p-img">
                                                <!-- Shows the product image, fallback to placeholder -->
                                                <img src="@imgPath" alt="@p.Name" onerror="this.src='/images/products/_placeholder.jpg'">
                                            </div>
                                            <div class="p-body">
                                                <div class="p-name">@p.Name</div>          <!-- Product name -->
                                                <div class="p-class">@p.Class</div>        <!-- Product class/category -->
                                            </div>
                                        </article>
                                    }
                                </div>
                            </div>
                        }
                    </section>
                }
            </div>
        }
    </div>
</section>
