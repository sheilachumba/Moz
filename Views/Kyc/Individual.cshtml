@model ClientPortal.Models.IndividualKyc
@{
    Layout = "_Layout";
    ViewData["Title"] = "Individual KYC (Mozambique)";
    var canSubmit = (bool)(ViewBag.CanSubmit ?? false);
    var identityTypes = ViewBag.IdentityTypes as List<SelectListItem> ?? new();
    var addressTypes = ViewBag.AddressTypes as List<SelectListItem> ?? new();
    var incomeProofTypes = ViewBag.IncomeProofTypes as List<SelectListItem> ?? new();
}
<style>
    :root {
        --brand: #1a2555;
        --ink: #0f172a;
        --muted: #64748b;
        --bg: #f6f7fb;
        --card: #ffffff;
        --border: #e5e7eb;
        --accent: #0ea5e9;
        --radius: 16px;
        --shadow: 0 10px 24px rgba(16,24,40,.07);
        --danger: #dc2626;
        --success: #0f766e;
        --locked: #f9fafb;
    }

    /* Global size & rhythm */
    html {
        font-size: 18px;
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
    }

    body {
        line-height: 1.6;
    }

    /* Page shell */
    .kyc-wrap {
        background: var(--bg);
        padding: 24px 0 56px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--ink);
    }

    .kyc-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Header */
    .kyc-header {
        margin-bottom: 18px;
    }

    .kyc-title {
        font-size: clamp(26px, 2.8vw, 36px);
        font-weight: 800;
        color: var(--brand);
    }

    .kyc-sub {
        color: var(--muted);
        font-size: 1rem;
        margin-top: 6px;
    }

    /* Legal box (replaces your subtext) */
    .kyc-legal {
        background: #f7f9ff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px 18px;
        margin: 12px 0 20px;
        color: #374151;
        font-size: 1.05rem;
    }

    .kyc-legal-title {
        color: var(--brand);
        font-weight: 800;
        margin-bottom: 8px;
        font-size: 1.05rem;
    }

    .kyc-legal-note {
        margin-top: 10px;
        color: #6b7280; /* fixed typo */
        font-size: .98rem;
    }

    .kyc-sub .req {
        color: #c32127;
        font-weight: 700;
    }

    /* Cards / sections */
    fieldset.kyc-card,
    .kyc-card {
        position: relative;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 26px;
        margin-bottom: 18px;
    }

        .kyc-card h3 {
            margin: 0 0 16px;
            font-size: 1.3rem; /* ~23px */
            font-weight: 800;
            color: var(--ink);
        }

    .helper {
        margin: -4px 0 14px;
        color: var(--muted);
        font-size: 1rem;
    }

    /* Locked state */
    .is-locked {
        background: var(--locked);
        filter: saturate(.65);
    }

        .is-locked::after {
            content: "Locked";
            position: absolute;
            top: 12px;
            right: 14px;
            font-size: .8rem;
            color: #6b7280;
            background: #eef2ff;
            border: 1px solid #e5e7eb;
            padding: 3px 10px;
            border-radius: 999px;
        }

    /* Grid */
    .grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(12, 1fr);
    }

    .col-12 {
        grid-column: span 12;
    }

    .col-9 {
        grid-column: span 9;
    }

    .col-8 {
        grid-column: span 8;
    }

    .col-6 {
        grid-column: span 6;
    }

    .col-4 {
        grid-column: span 4;
    }

    .col-3 {
        grid-column: span 3;
    }
    @@media (max-width: 900px) {
        .col-9, .col-8, .col-6, .col-4, .col-3

    {
        grid-column: span 12;
    }

    }

    /* Labels & inputs */
    label {
        display: block;
        font-size: 1rem;
        color: var(--muted);
        margin-bottom: 8px;
        font-weight: 700;
    }

    .form-control,
    select,
    textarea,
    input[type="file"] {
        width: 100%;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 14px 14px;
        font-size: 1rem;
        color: var(--ink);
        transition: box-shadow .15s ease, border-color .15s ease, background .15s ease;
    }

        .form-control:focus,
        select:focus,
        textarea:focus,
        input[type="file"]:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 4px rgba(14,165,233,.15);
            background: #fff;
        }

    /* Inline options */
    .inline {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        border: 1px solid var(--border);
        padding: 10px 14px;
        border-radius: 999px;
        background: #fff;
        cursor: pointer;
        font-weight: 700;
        color: var(--ink);
    }

        .chip input {
            accent-color: var(--brand);
        }

    /* Misc text */
    .req {
        color: var(--danger);
        margin-left: 4px;
    }

    .row-hint, .disclaimer {
        font-size: .95rem;
        color: var(--muted);
        margin-top: 6px;
    }

    /* Pair layout */
    .pair {
        display: grid;
        grid-template-columns: 1fr minmax(220px, 28%);
        gap: 12px;
    }
    @@media (max-width: 900px) {
        .pair

    {
        grid-template-columns: 1fr;
    }

    }

    /* Action bar */
    .action-bar {
        position: sticky;
        bottom: 0;
        z-index: 10;
        margin-top: 20px;
        background: linear-gradient(180deg, rgba(246,247,251,.35), #fff 40%);
        padding: 14px 0 8px;
        border-top: 1px solid var(--border);
    }

    /* Buttons */
    .btn {
        border: 0;
        border-radius: 12px;
        padding: 14px 18px;
        font-weight: 800;
        cursor: pointer;
        font-size: 1rem;
        transition: transform .15s ease, box-shadow .15s ease, filter .15s ease, background .15s ease;
    }

        .btn + .btn {
            margin-left: 10px;
        }

    .btn-ghost {
        background: #fff;
        color: var(--ink);
        border: 1px solid var(--border);
    }

        .btn-ghost:hover {
            transform: translateY(-1px);
            background: #f7f9ff;
        }

    .btn-success {
        background: var(--success);
        color: #fff;
        box-shadow: 0 10px 20px rgba(15,118,110,.22);
    }

        .btn-success:hover {
            transform: translateY(-1px);
            filter: brightness(1.03);
        }

    /* Validation summary tweaks */
    .text-danger.validation-summary-errors ul {
        margin: 0 0 12px 18px;
    }
</style>


<div class="kyc-wrap">
    <div class="kyc-container">
        <div class="kyc-header">
            <div class="kyc-title">Customer File – KYC (Individuals & Sole Traders)</div>
            <div class="kyc-sub kyc-legal">
                <div class="kyc-legal-title">Legal basis — Mozambique Law No. 14/2023</div>

                <p>
                    The Law establishing the Legal Framework and Measures to Prevent and Combat Money Laundering and
                    Terrorism Financing, Law No. 14/2023, of August 28, 2023, was approved, the legal framework and
                    measures to prevent and combat the use of the financial system and non-financial entities for the
                    purposes of money laundering, terrorist financing and financing the proliferation of weapons of mass
                    destruction.
                </p>

                <p>
                    Within the scope of Know Your Customer (KYC) measures, it is necessary to implement the duty to
                    identify, verify, and perform due diligence measures as described in the same Law. Therefore, and in
                    order to ensure regulatory requirements, Standard Insurance requests your cooperation in providing the
                    following information:
                </p>

                <p class="kyc-legal-note">
                    <span class="req">*</span> Fields are required. Uploads are required inline before continuing.
                </p>
            </div>

        </div>

        <form asp-controller="Kyc" asp-action="Individual" method="post" enctype="multipart/form-data" id="kycForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <!-- 1) PERSONAL DATA -->
            <fieldset class="kyc-card" id="secPersonal">
                <h3>1) Personal Data</h3>

                <div class="grid">
                    <div class="col-4">
                        <label asp-for="FirstName">First Name <span class="req">*</span></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-4">
                        <label asp-for="MiddleName">Middle Name</label>
                        <input asp-for="MiddleName" class="form-control" />
                        <span asp-validation-for="MiddleName" class="text-danger"></span>
                    </div>

                    <div class="col-4">
                        <label asp-for="LastName">Last Name <span class="req">*</span></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-4">
                        <label asp-for="DateOfBirth">Date of Birth <span class="req">*</span></label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>

                    <!-- Nationality: free text (BC will pick it up) -->
                    <div class="col-4">
                        <label for="Nationality">Nationality <span class="req">*</span></label>
                        <input type="text" name="Nationality" id="Nationality" class="form-control" />
                    </div>

                    <div class="col-4">
                        <label asp-for="Gender">Gender <span class="req">*</span></label>
                        <select asp-for="Gender" class="form-control">
                            <option value="">Select gender</option>
                            <option>Female</option>
                            <option>Male</option>
                            <option>Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>

                    <div class="col-4">
                        <label asp-for="MaritalStatus">Marital Status</label>
                        <select asp-for="MaritalStatus" class="form-control">
                            <option value="">Select marital status</option>
                            <option>Single</option>
                            <option>Married</option>
                            <option>Divorced</option>
                            <option>Widowed</option>
                        </select>
                        <span asp-validation-for="MaritalStatus" class="text-danger"></span>
                    </div>

                    <!-- Identity proof (multiple) -->
                    <div class="col-12">
                        <label>Identification Documents <span class="req">*</span></label>

                        <!-- Choice chips built from controller-supplied list -->
                        <div class="inline">
                            @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.IdentityTypes)
                            {
                                <label class="chip">
                                    <input type="checkbox"
                                           class="id-type"
                                           value="@item.Value"
                                           data-label="@item.Text" />
                                    @item.Text
                                </label>
                            }
                        </div>
                        <div class="row-hint">Select all that apply. Each selection will require a number and a file.</div>
                    </div>

                    <!-- Dynamic fields appear here for each selected document -->
                    <div id="IdDocsFields" class="col-12"></div>

                    <div class="col-4">
                        <label asp-for="Phone">Contact Number <span class="req">*</span></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="col-4">
                        <label asp-for="Email">E-mail</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- NUIT lives in Personal Data now -->
                    <div class="col-4">
                        <label asp-for="NUIT">NUIT (9 digits) <span class="req">*</span></label>
                        <input asp-for="NUIT"
                               id="NUIT"
                               class="form-control"
                               inputmode="numeric"
                               pattern="\d{9}"
                               minlength="9"
                               maxlength="9 />
                        <span class="row-hint">Exactly 9 digits (no spaces).</span>
                        <span asp-validation-for="NUIT" class="text-danger"></span>
                    </div>
                    <div class="col-4">
                        <label for="NuitFile">Attach NUIT Document <span class="req">*</span></label>
                        <input type="file" name="NuitFile" id="NuitFile" class="form-control" />
                    </div>

                    <div class="col-4">
                        <label asp-for="Phone">Contact Number <span class="req">*</span></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="col-4">
                        <label asp-for="Email">E-mail</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
            </fieldset>
          

            <!-- 3) PERSONAL ADDRESS -->
            <fieldset class="kyc-card is-locked" id="secAddress" disabled>
                <h3>3) Personal Address</h3>
                <div class="grid">
                    <div class="col-12">
                        <label asp-for="AddressLine">Physical Address <span class="req">*</span></label>
                        <input asp-for="AddressLine" class="form-control" placeholder="House / Street / City / Province" />
                        <span asp-validation-for="AddressLine" class="text-danger"></span>
                    </div>
                    @* <div class="col-6">
                        <label asp-for="Country">Country</label>
                        <input asp-for="Country" class="form-control" />
                        <span asp-validation-for="Country" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label for="Province">Province</label>
                        <input type="text" name="Province" id="Province" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label for="StreetNeighborhood">Street / Neighborhood</label>
                        <input type="text" name="StreetNeighborhood" id="StreetNeighborhood" class="form-control" />
                    </div> *@
                </div>
            </fieldset>

            <!-- 4) PROFESSIONAL DATA -->
            <fieldset class="kyc-card is-locked" id="secProfessional" disabled>
                <h3>4) Professional Data</h3>
                <div class="grid">
                    <div class="col-12">
                        <label for="EmployerAddress">Physical Address of Employer</label>
                        <input type="text" name="EmployerAddress" id="EmployerAddress" class="form-control" />
                    </div>
                    @* <div class="col-6">
                        <label for="EmployerCountry">Country</label>
                        <input type="text" name="EmployerCountry" id="EmployerCountry" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label for="EmployerProvince">Province</label>
                        <input type="text" name="EmployerProvince" id="EmployerProvince" class="form-control" />
                    </div> *@
                    <div class="col-6">
                        <label for="ProfessionFunction">Profession / Function</label>
                        <input type="text" name="ProfessionFunction" id="ProfessionFunction" class="form-control" />
                    </div>
                </div>
            </fieldset>

            <!-- 5) PEP -->
            <fieldset class="kyc-card is-locked" id="secPep" disabled>
                <h3>5) Politically Exposed Person (PEP)</h3>
                <p class="helper">PEP includes holders of prominent public functions (last 2 years), first-degree relatives, and close associates.</p>
                <div class="grid">
                    <div class="col-12">
                        <div class="inline" role="group" aria-label="PEP status">
                            <label class="chip"><input type="radio" name="PepStatus" value="Not PEP" checked /> I'm not PEP</label>
                            <label class="chip"><input type="radio" name="PepStatus" value="PEP-Direct" /> PEP – Direct</label>
                            <label class="chip"><input type="radio" name="PepStatus" value="PEP-Associate" /> PEP – Associate</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label for="PepDetails">If PEP, specify role/office, institution & period</label>
                        <input type="text" name="PepDetails" id="PepDetails" class="form-control" />
                    </div>
                </div>
            </fieldset>
            <!-- 5) PRODUCTS & SERVICES -->
            <fieldset class="kyc-card" id="secProducts">
                <h3>5) Products &amp; Services</h3>

                <div class="grid">
                    <!-- PRODUCT CLASS -->
                    <div class="col-6">
                        <label for="ProductClass">Product Class <span class="req">*</span></label>
                        <select id="ProductClass" name="ProductClass" class="form-control" required>
                            <option value="">Select product class</option>
                            <option value="Motor">Motor</option>
                            <option value="WorkmenCompensation">Workmen Compensation</option>
                            <option value="PersonalAccidents">Personal Accidents</option>
                            <option value="Engineering">Engineering</option>
                            <option value="Specialized">Specialized</option>
                            <option value="Multimark">Multimark</option>
                            <option value="HealthLife">Health &amp; Life</option>
                            <option value="Funeral">Funeral</option>
                        </select>
                    </div>

                    <!-- PRODUCT SUBCLASS -->
                    <div class="col-6">
                        <label for="ProductSubClass">Product Subclass</label>
                        <select id="ProductSubClass" name="ProductSubClass" class="form-control">
                            <option value="">Select subclass (optional)</option>
                        </select>
                    </div>
                </div>

                <!-- ================== REQUIREMENT BLOCKS ================== -->
                <!-- MOTOR -->
                <div class="col-12 svc" id="svc-Motor" style="display:none;">
                    <div class="grid">
                        <div class="col-4">
                            <label for="VehicleMake">Vehicle Make</label>
                            <input type="text" name="VehicleMake" id="VehicleMake" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label for="VehicleModel">Vehicle Model</label>
                            <input type="text" name="VehicleModel" id="VehicleModel" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label for="VehicleYear">Year</label>
                            <input type="number" name="VehicleYear" id="VehicleYear" class="form-control" min="1900" max="2100" />
                        </div>
                        <div class="col-4">
                            <label for="RegistrationNumber">Registration Number</label>
                            <input type="text" name="RegistrationNumber" id="RegistrationNumber" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label for="DriversLicenseNumber">Driver's License Number <span class="req">*</span></label>
                            <input type="text" name="DriversLicenseNumber" id="DriversLicenseNumber" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label for="DriversLicenseFile">Attach Driver’s License <span class="req">*</span></label>
                            <input type="file" name="DriversLicenseFile" id="DriversLicenseFile" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- WORKMEN COMPENSATION -->
                <div class="col-12 svc" id="svc-WorkmenCompensation" style="display:none;">
                    <div class="grid">
                        <div class="col-4">
                            <label for="EmployeeCount">Employee Count</label>
                            <input type="number" min="1" name="EmployeeCount" id="EmployeeCount" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label for="AnnualPayroll">Annual Payroll (MZN)</label>
                            <input type="number" min="0" step="0.01" name="AnnualPayroll" id="AnnualPayroll" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label for="OccupationRisk">Occupation Risk Class</label>
                            <input type="text" name="OccupationRisk" id="OccupationRisk" class="form-control" placeholder="e.g., Low / Medium / High" />
                        </div>
                    </div>
                </div>

                <!-- PERSONAL ACCIDENTS -->
                <div class="col-12 svc" id="svc-PersonalAccidents" style="display:none;">
                    <div class="grid">
                        <div class="col-6">
                            <label for="PAType">Cover Type</label>
                            <select id="PAType" name="PAType" class="form-control">
                                <option value="">Select</option>
                                <option>Individual</option>
                                <option>Group</option>
                                <option>GPA</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label for="PASumAssured">Sum Assured (MZN)</label>
                            <input type="number" min="0" step="0.01" id="PASumAssured" name="PASumAssured" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- ENGINEERING -->
                <div class="col-12 svc" id="svc-Engineering" style="display:none;">
                    <div class="grid">
                        <div class="col-6">
                            <label for="ProjectName">Project / Contract Name</label>
                            <input type="text" id="ProjectName" name="ProjectName" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label for="ContractValue">Contract Value (MZN)</label>
                            <input type="number" min="0" step="0.01" id="ContractValue" name="ContractValue" class="form-control" />
                        </div>
                        <div class="col-8">
                            <label for="SiteAddress">Site Address</label>
                            <input type="text" id="SiteAddress" name="SiteAddress" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label for="ProjectDurationMonths">Duration (months)</label>
                            <input type="number" min="1" id="ProjectDurationMonths" name="ProjectDurationMonths" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- SPECIALIZED -->
                <div class="col-12 svc" id="svc-Specialized" style="display:none;">
                    <label for="SpecializedDesc">Describe the specialized cover required</label>
                    <textarea id="SpecializedDesc" name="SpecializedDesc" rows="3" class="form-control" placeholder="e.g., Cyber, Political Violence, Credit, Aviation, Marine, etc."></textarea>
                </div>

                <!-- MULTIMARK -->
                <div class="col-12 svc" id="svc-Multimark" style="display:none;">
                    <label for="MultimarkNotes">Multimark cover notes / scope</label>
                    <textarea id="MultimarkNotes" name="MultimarkNotes" rows="3" class="form-control" placeholder="Summarize the required sections & limits."></textarea>
                </div>

                <!-- HEALTH & LIFE (MERGED) -->
                <div class="col-12 svc" id="svc-HealthLife" style="display:none;">
                    <div class="grid">
                        <div class="col-6">
                            <label for="PlanType">Plan Type</label>
                            <select name="PlanType" id="PlanType" class="form-control">
                                <option value="">Select</option>
                                <option>Individual</option>
                                <option>Family</option>
                                <option>Corporate</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label for="DependentsCount">Number of Dependents</label>
                            <input type="number" name="DependentsCount" id="DependentsCount" class="form-control" min="0" />
                        </div>
                        <div class="col-6">
                            <label for="BeneficiaryName">Beneficiary's Name</label>
                            <input type="text" name="BeneficiaryName" id="BeneficiaryName" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label for="BeneficiaryRelation">Beneficiary Relationship</label>
                            <input type="text" name="BeneficiaryRelation" id="BeneficiaryRelation" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label for="SumAssured">Sum Assured (MZN)</label>
                            <input type="number" name="SumAssured" id="SumAssured" class="form-control" min="0" step="0.01" />
                        </div>
                    </div>
                </div>

                <!-- FUNERAL -->
                <div class="col-12 svc" id="svc-Funeral" style="display:none;">
                    <div class="grid">
                        <div class="col-6">
                            <label for="FuneralCoverType">Funeral Cover Type</label>
                            <select id="FuneralCoverType" name="FuneralCoverType" class="form-control">
                                <option value="">Select</option>
                                <option>Individual</option>
                                <option>Family</option>
                                <option>Group</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label for="FuneralSumAssured">Sum Assured (MZN)</label>
                            <input type="number" min="0" step="0.01" id="FuneralSumAssured" name="FuneralSumAssured" class="form-control" />
                        </div>
                    </div>
                </div>
            </fieldset>
            <!-- 7) OTHER DATA -->
            <fieldset class="kyc-card is-locked" id="secOther" disabled>
                <h3>7) Other Data</h3>
                <div class="grid">
                    <div class="col-12">
                        <label>Do you hold a stake in any company/entity?</label>
                        <div class="inline">
                            <label class="chip"><input type="radio" name="HasStake" value="No" checked /> No</label>
                            <label class="chip"><input type="radio" name="HasStake" value="Yes" /> Yes</label>
                        </div>
                    </div>
                    <div class="col-8">
                        <label for="StakeEntity">If yes, name of entity</label>
                        <input type="text" name="StakeEntity" id="StakeEntity" class="form-control" />
                    </div>
                    <div class="col-4">
                        <label for="StakePercent">Percentage (%)</label>
                        <input type="number" step="0.01" min="0" max="100" name="StakePercent" id="StakePercent" class="form-control" />
                    </div>
                </div>
            </fieldset>

            <!-- 8) PROOF OF ADDRESS -->
            <fieldset class="kyc-card is-locked" id="secProofAddress" disabled>
                <h3>8) Proof of Address</h3>
                <div class="grid">
                    <div class="col-8">
                        <label asp-for="AddressProofType">Address Proof Type <span class="req">*</span></label>
                        <select asp-for="AddressProofType" class="form-control" asp-items="ViewBag.AddressTypes" id="AddressProofType"></select>
                        <span asp-validation-for="AddressProofType" class="text-danger"></span>
                    </div>
                    <div class="col-4">
                        <label for="AddressProofFile">Attach Address Proof <span class="req">*</span></label>
                        <input type="file" name="AddressProofFile" id="AddressProofFile" class="form-control" required />
                    </div>
                </div>
            </fieldset>

            <!-- 9) SOURCE OF INCOME -->
            <fieldset class="kyc-card is-locked" id="secIncome" disabled>
                <h3>9) Source of Income</h3>
                <div class="grid">
                    <div class="col-8">
                        <label asp-for="IncomeProofType">Income Proof Type <span class="req">*</span></label>
                        <select asp-for="IncomeProofType" class="form-control" asp-items="ViewBag.IncomeProofTypes" id="IncomeProofType"></select>
                        <span asp-validation-for="IncomeProofType" class="text-danger"></span>
                    </div>
                    <div class="col-4">
                        <label for="IncomeProofFile">Attach Income Proof <span class="req">*</span></label>
                        <input type="file" name="IncomeProofFile" id="IncomeProofFile" class="form-control" required />
                    </div>
                </div>
            </fieldset>

            <!-- 10) PASSPORT PHOTO (OPTIONAL) -->
            @* <fieldset class="kyc-card is-locked" id="secPhoto" disabled>
                <h3>10) Recent Passport Photo (Optional)</h3>
                <input type="file" name="PassportPhotoFile" class="form-control" />
            </fieldset> *@

            <!-- 11) SIGNATURES & DECLARATION -->
            <fieldset class="kyc-card is-locked" id="secSignatures" disabled>
                <h3>10) Signatures & Declaration</h3>
                <div class="grid">
                    <div class="col-12">
                        <label class="inline" style="gap:10px;">
                            <input type="checkbox" name="ConsentAccuracy" value="true" required />
                            <span>I declare that all information provided is true.</span>
                        </label>
                    </div>
                    <div class="col-6">
                        <label for="CustomerSignatureName">Customer Name (as on ID)</label>
                        <input type="text" name="CustomerSignatureName" id="CustomerSignatureName" class="form-control" />
                    </div>
                    <div class="col-3">
                        <label for="CustomerSignatureDate">Date</label>
                        <input type="date" name="CustomerSignatureDate" id="CustomerSignatureDate" class="form-control" />
                    </div>
                    <div class="col-3">
                        <label for="CustomerSignatureFile">Signature (optional upload)</label>
                        <input type="file" name="CustomerSignatureFile" id="CustomerSignatureFile" class="form-control" />
                    </div>

              @*       <div class="col-6">
                        <label for="OfficerName">Standard Insurance – Officer Name</label>
                        <input type="text" name="OfficerName" id="OfficerName" class="form-control" />
                    </div>
                    <div class="col-3">
                        <label for="OfficerDate">Date</label>
                        <input type="date" name="OfficerDate" id="OfficerDate" class="form-control" />
                    </div>
                    <div class="col-3">
                        <label for="EmployeeNumber">Employee Number</label>
                        <input type="text" name="EmployeeNumber" id="EmployeeNumber" class="form-control" />
                    </div>
                </div> *@
                <div class="disclaimer" style="margin-top:10px;">
                    Note: Additional verification may be requested to comply with Mozambican AML/CFT requirements.
                </div>
            </fieldset>

            <!-- Actions -->
            <div class="action-bar">
                <div class="kyc-container" style="display:flex; justify-content:flex-end;">
                    <button name="action" value="save" class="btn btn-ghost" type="submit">Save Draft</button>
                    <button name="action" value="submit" class="btn btn-success" type="submit">Submit</button>
                </div>
            </div>

        </form>
    </div>
</div>

<script>
    (function () {
      // ---------- sections to lock/unlock (after Personal Data) ----------
      const secIds = [
        'secAddress','secProfessional','secPep',
        'secProducts','secOther','secProofAddress','secIncome','secSignatures'
      ];
      const sections = Object.fromEntries(secIds.map(id => [id, document.getElementById(id)]));

      function setLocked(el, locked){
        if(!el) return;
        el.disabled = !!locked;
        el.classList.toggle('is-locked', !!locked);
      }
      function lockAllAfterPersonal(){ Object.values(sections).forEach(s => setLocked(s, true)); }
      function unlockAllAfterPersonal(){ Object.values(sections).forEach(s => setLocked(s, false)); }

      // ---------- multiple identity documents (dynamic fields) ----------
      const idContainer = document.getElementById('IdDocsFields');  // where groups are inserted
      const idChecks    = document.querySelectorAll('.id-type');    // checkboxes from ViewBag.IdentityTypes

      function addIdGroup(value, label){
        if(!idContainer || idContainer.querySelector(`.id-doc[data-type="${value}"]`)) return;
        const html = `
          <div class="kyc-card id-doc" data-type="${value}" style="padding:16px; margin-top:10px;">
            <input type="hidden" name="IdentityDocs.Index" value="${value}">
            <input type="hidden" name="IdentityDocs[${value}].Type" value="${value}">
            <div class="grid">
              <div class="col-6">
                <label>${label} Number <span class="req">*</span></label>
                <input type="text" class="form-control" name="IdentityDocs[${value}].Number" required>
              </div>
              <div class="col-6">
                <label>Attach ${label} <span class="req">*</span></label>
                <input type="file" class="form-control" name="IdentityDocs[${value}].File" required>
              </div>
            </div>
          </div>`;
        idContainer.insertAdjacentHTML('beforeend', html);
        updateGate();
      }
      function removeIdGroup(value){
        if(!idContainer) return;
        const el = idContainer.querySelector(`.id-doc[data-type="${value}"]`);
        if(el) el.remove();
        updateGate();
      }
      idChecks.forEach(cb => {
        cb.addEventListener('change', () => {
          const label = cb.dataset.label || cb.value;
          cb.checked ? addIdGroup(cb.value, label) : removeIdGroup(cb.value);
        });
      });
      // If some were prechecked (e.g., draft), render them:
      idChecks.forEach(cb => { if (cb.checked) addIdGroup(cb.value, cb.dataset.label || cb.value); });

      function identityReady(){
        if(!idContainer) return false;
        const groups = idContainer.querySelectorAll('.id-doc');
        if(!groups.length) return false;
        for(const g of groups){
          const num  = g.querySelector('input[type="text"]');
          const file = g.querySelector('input[type="file"]');
          if(!num || !num.value.trim()) return false;
          if(!file || !(file.files && file.files.length)) return false;
        }
        return true;
      }

      // ---------- NUIT (exactly 9 digits) ----------
      const nuit     = document.getElementById('NUIT');
      const nuitFile = document.getElementById('NuitFile');

      nuit?.addEventListener('input', function(){
        this.value = this.value.replace(/\D/g,'').slice(0,9);
        if(this.value.length === 9){ this.setCustomValidity(''); }
        else { this.setCustomValidity('NUIT must be exactly 9 digits.'); }
      });

      // ---------- gate: unlock rest after personal-docs + nuit complete ----------
      function updateGate(){
        const okId   = identityReady();
        const okNuit = !!(nuit && nuit.value.length === 9);
        const okNf   = !!(nuitFile && nuitFile.files && nuitFile.files.length);
        (okId && okNuit && okNf) ? unlockAllAfterPersonal() : lockAllAfterPersonal();
      }
      idContainer?.addEventListener('input',  updateGate);
      idContainer?.addEventListener('change', updateGate);
      nuit?.addEventListener('input',         updateGate);
      nuitFile?.addEventListener('change',    updateGate);
      updateGate(); // init

         (function () {
      const cls = document.getElementById('ProductClass');
      const sub = document.getElementById('ProductSubClass');
      const sections = Array.from(document.querySelectorAll('#secProducts .svc'));

      const subclasses = {
        "Motor": [["ThirdParty", "Third Party"], ["Comprehensive", "Comprehensive"]],
        "WorkmenCompensation": [["Statutory", "Statutory"], ["EmployerLiability", "Employer’s Liability"]],
        "PersonalAccidents": [["Individual", "Individual"], ["Group", "Group"]],
        "Engineering": [["CAR", "Contractors All Risk"], ["EAR", "Erection All Risk"]],
        "Specialized": [["Cyber", "Cyber"], ["Aviation", "Aviation"], ["Marine", "Marine"]],
        "Multimark": [["General", "General Multimark"]],
        "HealthLife": [["Health", "Health"], ["Life", "Life"]],
        "Funeral": [["Individual", "Individual"], ["Family", "Family"], ["Group", "Group"]]
      };

      function setSubclasses(forClass) {
        sub.innerHTML = '<option value="">Select subclass (optional)</option>';
        (subclasses[forClass] || []).forEach(([v, t]) => {
          const opt = document.createElement('option');
          opt.value = v; opt.textContent = t;
          sub.appendChild(opt);
        });
      }

      function showSection(forClass) {
        sections.forEach(s => s.style.display = 'none');
        const el = document.getElementById('svc-' + forClass);
        if (el) el.style.display = '';
      }

      cls?.addEventListener('change', () => {
        const val = cls.value || '';
        setSubclasses(val);
        showSection(val);
      });

      if (cls && cls.value) {
        setSubclasses(cls.value);
        showSection(cls.value);
      }
    })();

      // ---------- final submit guard ----------
      const form = document.getElementById('kycForm');
      const addressProofFile = document.getElementById('AddressProofFile');
      const incomeProofFile  = document.getElementById('IncomeProofFile');

      form?.addEventListener('submit', function(e){
        if(!identityReady()){
          e.preventDefault(); alert('Please add at least one identification document with its number and file.'); return;
        }
        if(!(nuit && nuit.value.length === 9)){
          e.preventDefault(); alert('NUIT must be exactly 9 digits.'); return;
        }
        if(!(nuitFile && nuitFile.files.length)){
          e.preventDefault(); alert('Please attach the NUIT document.'); return;
        }
        if(!(addressProofFile && addressProofFile.files.length)){
          e.preventDefault(); alert('Please attach the Proof of Address before submitting.'); return;
        }
        if(!(incomeProofFile && incomeProofFile.files.length)){
          e.preventDefault(); alert('Please attach the Proof of Income before submitting.'); return;
        }

        const grp = classToGroup(productClass?.value || '');
        if(grp === 'Motor'){
          if(!(dlNum && dlNum.value.trim())){
            e.preventDefault(); alert("Please provide the Driver's License Number for Motor insurance."); return;
          }
          if(!(dlFile && dlFile.files.length)){
            e.preventDefault(); alert("Please attach the Driver's License for Motor insurance."); return;
          }
        }
      });
    })();
</script>


