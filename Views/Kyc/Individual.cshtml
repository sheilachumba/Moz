            </script> *@

            <!-- 3) PERSONAL ADDRESS -->
            <div class="col-4 form-group">
                <label asp-for="PostCode">Postal Code <span class="required"></span></label>
                <select asp-for="PostCode" class="form-control" asp-items="ViewBag.PostalCodes">
                    <option value="">Select postal code</option>
                </select>
                <span asp-validation-for="PostCode" class="field-validation-error"></span>
            </div>


            <!-- 4) PROFESSIONAL DATA -->
            <fieldset class="section locked" id="secProfessional">
                <h3 class="section-title">3) Professional Data</h3>
                <div class="grid">
                    <div class="col-12 form-group">
                        <label for="EmployerAddress">Physical Address of Employer</label>
                        <input type="text" name="EmployerAddress" id="EmployerAddress" class="form-control" />
                    </div>
                    <div class="col-6 form-group">
                        <label for="ProfessionFunction">Profession / Function</label>
                        <input type="text" name="ProfessionFunction" id="ProfessionFunction" class="form-control" />
                    </div>
                </div>
            </fieldset>

            <!-- 5) PEP -->
            <fieldset class="section locked" id="secPep">
                <h3 class="section-title">4) Politically Exposed Person (PEP)</h3>
                <p class="section-helper">PEP includes holders of prominent public functions (last 2 years), first-degree relatives, and close associates.</p>
                <div class="grid">
                    <div class="col-12 form-group">
                        <div class="chip-group" role="group" aria-label="PEP status">
                            <label class="chip"><input type="radio" name="PepStatus" value="Not PEP" checked /> I'm not PEP</label>
                            <label class="chip"><input type="radio" name="PepStatus" value="PEP-Direct" /> PEP – Direct</label>
                            <label class="chip"><input type="radio" name="PepStatus" value="PEP-Associate" /> PEP – Associate</label>
                        </div>
                    </div>
                    <div class="col-12 form-group">
                        <label for="PepDetails">If PEP, specify role/office, institution & period</label>
                        <input type="text" name="PepDetails" id="PepDetails" class="form-control" />
                    </div>
                </div>
            </fieldset>

             <!-- 6. BENEFICIARY INSTEAD OF PRODUCTS SERVICES -->
            <fieldset class="section locked" id="secBeneficiary">
                <h3 class="section-title">6 Beneficiary Name</h3>
                <div class="grid">
                    <div class="col-12 form-group">
                        <label for="BeneficiaryName">Beneficiary Name <span class="required"></span></label>
                        <input type="text" name="BeneficiaryName" id="BeneficiaryName" class="form-control" />
                    </div>
                </div>
            </fieldset>

            <!-- 7) OTHER DATA -->
            <fieldset class="section locked" id="secOther">
                <h3 class="section-title">6) Other Data</h3>
                <div class="grid">
                    <div class="col-12 form-group">
                        <label>Do you hold a stake in any company/entity?</label>
                        <div class="chip-group">
                            <label class="chip"><input type="radio" name="HasStake" value="No" checked /> No</label>
                            <label class="chip"><input type="radio" name="HasStake" value="Yes" /> Yes</label>
                        </div>
                    </div>
                    <div class="col-8 form-group">
                        <label for="StakeEntity">If yes, name of entity</label>
                        <input type="text" name="StakeEntity" id="StakeEntity" class="form-control" />
                    </div>
                    <div class="col-4 form-group">
                        <label for="StakePercent">Percentage (%)</label>
                        <input type="number" step="0.01" min="0" max="100" name="StakePercent" id="StakePercent" class="form-control" />
                    </div>
                </div>
            </fieldset>

            <!-- 8) PROOF OF ADDRESS -->
            <fieldset class="section locked" id="secProofAddress">
                <h3 class="section-title">7) Proof of Address</h3>
                <div class="grid">
                    <div class="col-8 form-group">
                        <label asp-for="AddressProofType">Address Proof Type <span class="required">*</span></label>
                        <select asp-for="AddressProofType" class="form-control" asp-items="addressTypes" id="AddressProofType"></select>
                        <span asp-validation-for="AddressProofType" class="field-validation-error"></span>
                    </div>
                    <div class="col-4 form-group">
                        <label for="AddressProofFile">Attach Address Proof <span class="required">*</span></label>
                        <input type="file" name="AddressProofFile" id="AddressProofFile" class="form-control" required />
                    </div>
                </div>
            </fieldset>

            <!-- 9) SOURCE OF INCOME -->
            <div class="col-4 form-group">
                <label asp-for="SourceOfFunds">Source of Funds</label>
                <select asp-for="SourceOfFunds" class="form-control" asp-items="ViewBag.SourceOfFunds">
                    <option value="">Select source</option>
                </select>
                <span asp-validation-for="SourceOfFunds" class="field-validation-error"></span>
            </div>


            <!-- 10) SIGNATURES & DECLARATION -->
            <fieldset class="section locked" id="secSignatures">
                <h3 class="section-title">9) Signatures & Declaration</h3>
                <div class="grid">
                    <div class="col-12 form-group">
                        <label class="chip">
                            <input type="checkbox" name="ConsentAccuracy" value="true" required />
                            <span>I declare that all information provided is true and accurate.</span>
                        </label>
                    </div>
                    <div class="col-6 form-group">
                        <label for="CustomerSignatureName">Customer Name (as on ID)</label>
                        <input type="text" name="CustomerSignatureName" id="CustomerSignatureName" class="form-control" />
                    </div>
                    <div class="col-3 form-group">
                        <label for="CustomerSignatureDate">Date</label>
                        <input type="date" name="CustomerSignatureDate" id="CustomerSignatureDate" class="form-control" />
                    </div>
                    <div class="col-3 form-group">
                        <label for="CustomerSignatureFile">Signature (optional upload)</label>
                        <input type="file" name="CustomerSignatureFile" id="CustomerSignatureFile" class="form-control" />
                    </div>
                </div>
                <div class="disclaimer">
                    Note: Additional verification may be requested to comply with Mozambican AML/CFT requirements.
                </div>
            </fieldset>

            <!-- Action Buttons -->
            <div class="action-bar">
                <div class="action-buttons">
                    <button name="action" value="save" class="btn btn-ghost" type="submit">Save Draft</button>
                    <button name="action" value="submit" class="btn btn-success" type="submit">Submit Application</button>
                </div>
            </div>
           
        </form>
    </div>
</section>

<script>
    (function () {
        // Section lock/unlock after Personal Data
        const secIds = [
            'secAddress', 'secProfessional', 'secPep',
            'secBeneficiary', 'secOther', 'secProofAddress', 'secIncome', 'secSignatures'
        ];
        const sections = Object.fromEntries(secIds.map(id => [id, document.getElementById(id)]));

        function setLocked(el, locked) {
            if (!el) return;
            if (locked) {
                el.classList.add('locked');
                el.querySelectorAll('input, select, textarea, button').forEach(input => {
                    input.disabled = true;
                });
            } else {
                el.classList.remove('locked');
                el.querySelectorAll('input, select, textarea, button').forEach(input => {
                    input.disabled = false;
                });
            }
        }

        function lockAllAfterPersonal() {
            Object.values(sections).forEach(s => setLocked(s, true));
        }

        function unlockAllAfterPersonal() {
            Object.values(sections).forEach(s => setLocked(s, false));
        }

        // NUIT validation (exactly 9 digits)
        const nuit = document.getElementById('NUIT');
        const nuitFile = document.getElementById('NuitFile');

        nuit?.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 9);
            if (this.value.length === 9) {
                this.setCustomValidity('');
            } else {
                this.setCustomValidity('NUIT must be exactly 9 digits.');
            }
            updateGate();
        });

        // Identity document dynamic fields (single selection, expiry date logic)
        const idContainer = document.getElementById("IdDocsFields");
        const idRadios = document.querySelectorAll(".id-type");
        function addIdGroup(value, label) {
            if (!idContainer || idContainer.querySelector('.id-doc[data-type="' + value + '"]')) return;
            let needsExpiry = label !== "National ID" && label !== "Birth Certificate";
            let expiryHtml = needsExpiry
                ? `<div class="col-6 form-group">
                        <label>Expiry Date<span class="required"></span></label>
                        <input type="date" class="form-control" name="IdentityDocs[${value}].ExpiryDate" required />
                   </div>`
                : "";
            const html =
                `<div class="document-group id-doc" data-type="${value}">
                    <div class="document-title">${label}</div>
                    <input type="hidden" name="IdentityDocs.Index" value="${value}" />
                    <input type="hidden" name="IdentityDocs[${value}].Type" value="${value}" />
                    <div class="grid">
                        <div class="col-6 form-group">
                            <label>${label} Number<span class="required"></span></label>
                            <input type="text" class="form-control" name="IdentityDocs[${value}].Number" required />
                        </div>
                        <div class="col-6 form-group">
                            <label>Attach ${label}<span class="required"></span></label>
                            <input type="file" class="form-control" name="IdentityDocs[${value}].File" required />
                        </div>
                        ${expiryHtml}
                    </div>
                </div>`;
            idContainer.innerHTML = html;
            updateGate();
        }
        function removeIdGroup() { idContainer.innerHTML = ""; }
        idRadios.forEach(cb => {
            cb.addEventListener("change", function () {
                removeIdGroup();
                if (this.checked) addIdGroup(cb.value, cb.dataset.label);
            });
        });

        function identityReady() {
            if (!idContainer) return false;
            const group = idContainer.querySelector('.id-doc');
            if (!group) return false;
            const num = group.querySelector('input[type="text"]');
            const file = group.querySelector('input[type="file"]');
            if (!num || !num.value.trim()) return false;
            if (!file || !(file.files && file.files.length)) return false;
            return true;
        }

        // Gate: unlock rest after personal-docs + nuit complete
        function updateGate() {
            const okId = identityReady();
            const okNuit = !!(nuit && nuit.value.length === 9);
            const okNf = !!(nuitFile && nuitFile.files && nuitFile.files.length);
            if (okId && okNuit && okNf) {
                unlockAllAfterPersonal();
            } else {
                lockAllAfterPersonal();
            }
        }

        idContainer?.addEventListener('input', updateGate);
        idContainer?.addEventListener('change', updateGate);
        nuit?.addEventListener('input', updateGate);
        nuitFile?.addEventListener('change', updateGate);

        // Initialize
        lockAllAfterPersonal();
        updateGate();

        // Final submit guard
        const form = document.getElementById('kycForm');
        const addressProofFile = document.getElementById('AddressProofFile');
        const incomeProofFile = document.getElementById('IncomeProofFile');

        form?.addEventListener('submit', function (e) {
            if (!identityReady()) {
                e.preventDefault();
                alert('Please add one identification document with its number and file.');
                return;
            }
            if (!(nuit && nuit.value.length === 9)) {
                e.preventDefault();
                alert('NUIT must be exactly 9 digits.');
                return;
            }
            if (!(nuitFile && nuitFile.files.length)) {
                e.preventDefault();
                alert('Please attach the NUIT document.');
                return;
            }
            if (!(addressProofFile && addressProofFile.files.length)) {
                e.preventDefault();
                alert('Please attach the Proof of Address before submitting.');
                return;
            }
            if (!(incomeProofFile && incomeProofFile.files.length)) {
                e.preventDefault();
                alert('Please attach the Proof of Income before submitting.');
                return;
            }
        });
    })();
</script>
