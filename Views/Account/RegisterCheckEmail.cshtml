@{
    ViewData["Title"] = "Check Email";
    Layout = "_Layout";
}
<style>
    body {
        background: #f6f8fc;
        min-height: 100vh;
    }

    .email-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 85vh;
        padding-top: 25px;
    }

    .email-card {
        background: #fff;
        border-radius: 12px;
        max-width: 420px;
        padding: 38px 32px 32px 32px;
        margin: 0 auto;
        box-shadow: 0 4px 28px 0 rgba(34, 48, 106, 0.16);
        border: 1px solid #e1e4ed;
        text-align: center;
        position: relative;
    }

        .email-card .email-icon {
            font-size: 55px;
            color: #234ca7;
            margin-bottom: 15px;
        }

        .email-card h3 {
            color: #1e366a;
            font-size: 1.65rem;
            font-weight: 700;
            margin-bottom: 6px;
            letter-spacing: 0.01em;
        }

        .email-card p {
            color: #22305c;
            line-height: 1.7;
            font-size: 1.12rem;
            margin-bottom: 0;
        }

    .brand {
        font-size: 1.09rem;
        color: #192f62;
        margin-bottom: 25px;
        font-weight: 500;
        letter-spacing: 0.04em;
    }
    @@media (max-width: 600px) {
        .email-card

    {
        padding: 17px 6px 14px 6px;
    }

    }
</style>
<div class="email-wrapper">
    <div class="email-card">
        <div class="brand">Standard Insurance Mozambique</div>
        <div class="email-icon">
            <svg height="55" width="55" fill="#234ca7" viewBox="0 0 24 24">
                <path d="M2.01 6.81A2.994 2.994 0 0 1 5 5h14c1.3 0 2.4.84 2.83 2.02l-9.16 7.11a1.73 1.73 0 0 1-2.14 0L2.01 6.81zm-.01 2.66V17c0 1.1.9 2 2 2h16a2 2 0 0 0 2-2V9.47l-7.88 6.11a3.73 3.73 0 0 1-4.24 0L2 9.47z" />
            </svg>
        </div>
        <h3>Almost there!</h3>
        <p>We sent a verification link to your email.<br> Click it to activate your account, then log in.</p>
    </div>
</div>
