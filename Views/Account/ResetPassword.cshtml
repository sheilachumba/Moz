@model ClientPortal.Models.ResetPasswordVm
@{
	Layout = "_Layout";
}
<h3>Reset Password</h3>
<form asp-action="ResetPassword" method="post">
	<input type="hidden" asp-for="Token" />
	<label>Email <input asp-for="Email" /></label>
	<label>New Password <input asp-for="NewPassword" /></label>
	<label>Confirm Password <input asp-for="ConfirmPassword" /></label>
	<button class="primary">Reset</button>
</form>
