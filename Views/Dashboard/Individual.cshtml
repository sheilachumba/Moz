@using ClientPortal.Models
@model ClientPortal.Models.ApplicationUser
@{
    ViewData["Title"] = "Individual Dashboard";
    Layout = "_Layout";
}

@{
    var kycStatusRaw = ViewBag.KycStatus as string ?? "";
    KycStatus kycStatusEnum;
    Enum.TryParse(kycStatusRaw, out kycStatusEnum);
}

<style>
    /* ===== Dashboard Theme (scoped with .dash) ===== */
    .dash {
        --brand: #1a2555; /* Deep navy blue */
        --brand-2: #2d3b8b; /* Medium blue */
        --brand-light: #4f63c1; /* Light blue */
        --bg: #f8fafc; /* Very light gray background */
        --card: #ffffff; /* White cards */
        --text: #0f172a; /* Near black for text */
        --text-muted: #334155; /* Dark gray */
        --muted: #64748b; /* Medium gray */
        --muted-light: #cbd5e1; /* Light gray */
        --ok: #059669; /* Green */
        --warn: #d97706; /* Amber */
        --bad: #dc2626; /* Red */
        --border: #e2e8f0; /* Light border */
        --ring: #3b82f6; /* Blue ring */
        --radius: 12px;
        --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
        --shadow-lg: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

        .dash * {
            box-sizing: border-box;
        }

        .dash .wrap {
            max-width: 1280px;
            margin: 0 auto;
            padding: 24px 16px 60px;
            background: var(--bg);
        }

        .dash h1 {
            margin: 0;
            color: var(--brand);
            font-weight: 800;
            font-size: clamp(24px, 2.5vw, 32px);
            font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        }

        .dash .sub {
            color: var(--muted);
            margin-top: 6px;
            font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        }

        /* ===== Shell: sidebar + main ===== */
        .dash .shell {
            display: grid;
            gap: 24px;
            grid-template-columns: 260px 1fr;
            align-items: start;
            font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        }

    @@media (max-width: 980px) {
        .dash .shell {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }

    /* ===== Sidebar ===== */
    .dash .side {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        position: sticky;
        top: 16px;
        overflow: hidden;
    }

        .dash .side .hd {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            font-weight: 700;
            color: var(--brand);
            background: var(--bg);
            font-size: 16px;
            font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        }

        .dash .side nav {
            padding: 12px 8px;
        }

    .dash .link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        font-size: 14px;
        transition: all 0.2s ease;
        margin: 4px 0;
    }

        .dash .link:hover {
            background: #f1f5f9;
            color: var(--brand);
        }

        .dash .link.active {
            background: var(--brand);
            color: white;
            font-weight: 600;
        }

    .dash .sep {
        height: 1px;
        background: var(--border);
        margin: 8px 12px;
    }

    @@media (max-width: 980px) {
        .dash .side {
            position: static;
        }

            .dash .side .hd {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .dash .side[aria-expanded="false"] nav {
                display: none;
            }
    }

    /* ===== Header row inside main ===== */
    .dash .hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
        padding: 0 4px;
    }

        .dash .hdr .right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

    .dash .notif {
        position: relative;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--card);
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .dash .notif:hover {
            border-color: var(--brand-light);
            box-shadow: var(--shadow);
        }

        .dash .notif .badge {
            position: absolute;
            right: -4px;
            top: -4px;
            background: var(--bad);
            color: white;
            font-size: 11px;
            border-radius: 999px;
            padding: 2px 6px;
            line-height: 1;
            font-weight: 600;
            min-width: 18px;
            text-align: center;
        }

    /* ===== Hero Section ===== */
    .dash .hero-container {
        background: linear-gradient(135deg, var(--brand) 0%, var(--brand-2) 100%);
        border-radius: var(--radius);
        overflow: hidden;
        margin-bottom: 20px;
        box-shadow: var(--shadow-lg);
        position: relative;
    }

    .dash .hero-content {
        padding: 40px 32px;
        color: white;
        position: relative;
        z-index: 2;
    }

    .dash .hero-welcome {
        font-size: 28px;
        font-weight: 700;
        margin: 0 0 8px 0;
        color: white;
    }

    .dash .hero-user {
        font-size: 20px;
        font-weight: 600;
        margin: 0 0 16px 0;
        opacity: 0.95;
    }

    .dash .hero-description {
        font-size: 16px;
        margin: 0 0 24px 0;
        opacity: 0.9;
        max-width: 500px;
    }

    .dash .hero-image {
        position: absolute;
        right: 0;
        top: 0;
        height: 100%;
        width: 40%;
        object-fit: cover;
        border-radius: 0 var(--radius) var(--radius) 0;
    }

    @@media (max-width: 768px) {
        .dash .hero-image {
            width: 100%;
            opacity: 0.2;
            border-radius: var(--radius);
        }

        .dash .hero-content {
            padding: 32px 24px;
        }

        .dash .hero-welcome {
            font-size: 24px;
        }

        .dash .hero-user {
            font-size: 18px;
        }
    }

    .dash .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: white;
        color: var(--brand);
        text-decoration: none;
        border-radius: 8px;
        padding: 12px 20px;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

        .dash .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        }

    /* ===== Stat cards ===== */
    .dash .stats {
        margin-top: 0;
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
    }

    @@media (max-width: 1200px) {
        .dash .stats {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .dash .stats {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 480px) {
        .dash .stats {
            grid-template-columns: 1fr;
        }
    }

    .dash .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        box-shadow: var(--shadow);
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .dash .card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

    .dash .stat .k {
        font-size: 13px;
        color: var(--muted);
        font-weight: 500;
        margin-bottom: 8px;
    }

    .dash .stat .v {
        font-size: 24px;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 4px;
    }

    .dash .trend {
        font-size: 12px;
        font-weight: 500;
    }

        .dash .trend.up {
            color: var(--ok);
        }

        .dash .trend.down {
            color: var(--bad);
        }

    /* ===== 2-col sections ===== */
    .dash .grid2 {
        margin-top: 24px;
        display: grid;
        gap: 20px;
        grid-template-columns: 2fr 1.4fr;
    }

    @@media (max-width: 980px) {
        .dash .grid2 {
            grid-template-columns: 1fr;
        }
    }

    .dash table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    .dash thead th {
        text-align: left;
        color: var(--muted);
        font-weight: 600;
        font-size: 12px;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .dash tbody td {
        padding: 16px;
        border-bottom: 1px solid var(--border);
        color: var(--text-muted);
    }

    .dash tbody tr:last-child td {
        border-bottom: none;
    }

    .dash tbody tr:hover {
        background: var(--bg);
    }

    .dash .pill {
        font-size: 11px;
        border-radius: 999px;
        padding: 4px 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

        .dash .pill.ok {
            background: #f0fdf4;
            color: var(--ok);
            border: 1px solid #bbf7d0;
        }

        .dash .pill.bad {
            background: #fef2f2;
            color: var(--bad);
            border: 1px solid #fecaca;
        }

        .dash .pill.warn {
            background: #fffbeb;
            color: var(--warn);
            border: 1px solid #fed7aa;
        }

        .dash .pill.neutral {
            background: #f8fafc;
            color: var(--muted);
            border: 1px solid var(--border);
        }

    /* ===== Actions list ===== */
    .dash .actions .item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px;
        background: var(--card);
        transition: all 0.2s ease;
    }

        .dash .actions .item:hover {
            border-color: var(--brand-light);
            box-shadow: var(--shadow);
        }

        .dash .actions .item + .item {
            margin-top: 12px;
        }

    .dash .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--card);
        border: 1px solid var(--border);
        color: var(--brand);
        text-decoration: none;
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 500;
        transition: all 0.2s ease;
        white-space: nowrap;
    }

        .dash .btn-secondary:hover {
            background: var(--brand);
            color: white;
            border-color: var(--brand);
        }

    /* KYC Status Banner */
    .kyc-status-banner {
        padding: 16px 20px;
        border-radius: var(--radius);
        margin-bottom: 20px;
        font-weight: 600;
        border: 1px solid;
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .kyc-status-pending {
        background-color: #fffbeb;
        color: #92400e;
        border-color: #fcd34d;
    }

    .kyc-status-approved {
        background-color: #f0fdf4;
        color: #166534;
        border-color: #86efac;
    }

    /* Form Styles */
    .dash .input {
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 10px 12px;
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        font-size: 14px;
        transition: border-color 0.2s ease;
        background: var(--card);
    }

        .dash .input:focus {
            outline: none;
            border-color: var(--brand-light);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

    .dash textarea.input {
        resize: vertical;
        min-height: 80px;
    }
</style>

<section class="dash">
    <div class="wrap">
        <div class="shell">

            <!-- SIDEBAR -->
            <aside class="side" id="side" aria-expanded="true">
                <div class="hd">
                    Menu
                    <button class="btn-secondary" id="sideToggle" style="display:none;">Toggle</button>
                </div>
                <nav>
                    <a class="link active" asp-controller="Dashboard" asp-action="Individual"><span>Home</span></a>
                    <a class="link" asp-controller="Policies" asp-action="Index"><span>Policies</span></a>
                    <a class="link" asp-controller="Quotations" asp-action="Index"><span>Quotations</span></a>
                    <a class="link" asp-controller="Documents" asp-action="Index"><span>Documents</span></a>
                    <a class="link" asp-controller="Renewals" asp-action="Index"><span>Renewals</span></a>
                    <a class="link" asp-controller="Claims" asp-action="Index"><span>Claims</span></a>
                    <a class="link" asp-controller="Interactions" asp-action="Index"><span>Interactions</span></a>
                    <div class="sep"></div>
                    <a class="link" asp-controller="Products" asp-action="Index"><span>Products & Services</span></a>
                    <a class="link" asp-controller="Statements" asp-action="Index"><span>Statements</span></a>

                    <div class="sep"></div>
                    <a class="link" asp-controller="Settings" asp-action="Index"><span>Settings</span></a>
                </nav>
            </aside>

            <!-- MAIN -->
            <main>
                <!-- header row: title + notifications -->
                <div class="hdr">
                    <div>
                        <h1>Individual Dashboard</h1>
                        @* <div class="sub">Your policies, claims, renewals and documents at a glance</div> *@
                    </div>
                    <div class="right">
                        <a class="notif" asp-controller="Notifications" asp-action="Index" title="Notifications">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14v-2a6 6 0 1 0-12 0v2c0 .5-.2 1-.6 1.4L4 17h5" />
                                <path d="M9 20a3 3 0 0 0 6 0" />
                            </svg>
                            <span class="badge">@(Model?.UnreadNotificationsCount ?? 0)</span>
                        </a>
                    </div>
                </div>

                <!-- KYC Status Banner -->
                @if (kycStatusEnum == KycStatus.Submitted)
                {
                    <div class="kyc-status-banner kyc-status-pending">
                        <i class="bi bi-clock-history"></i> Your KYC application is under review
                    </div>
                }
                else if (kycStatusEnum == KycStatus.Verified)
                {
                    <div class="kyc-status-banner kyc-status-approved">
                        <i class="bi bi-check-circle"></i> Your KYC has been approved!
                    </div>
                }
                else if (kycStatusEnum == KycStatus.Draft)
                {
                    <div class="kyc-status-banner kyc-status-draft">
                        Your KYC is in draft status. Please complete the form.
                    </div>
                }
                else
                {
                    <div class="kyc-status-banner kyc-status-unknown">
                        KYC status unknown or not submitted.
                    </div>
                }


                <!-- Hero Section with User Welcome -->
                <div class="hero-container">
                    <div class="hero-content">
                        <div class="hero-welcome">Welcome to Your Dashboard</div>
                        <div class="hero-user">Hello, @($"{Model.FirstName} {Model.LastName}".Trim())!</div>
                        <div class="hero-description">Manage your insurance policies, track claims, and access all your documents in one place.</div>
                        <a href="#" class="btn-primary">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 5v14m-7-7h14" />
                            </svg>
                            Get Started
                        </a>
                    </div>
                    <img src="~/images/kyc-banner.png" alt="Insurance Dashboard" class="hero-image" onerror="this.style.display='none'" />
                </div>

                <!-- stats -->
                <div class="stats">
                    <div class="card stat">
                        <div class="k">Active Policies</div>
                        <div class="v">@(Model?.ActivePoliciesCount ?? 0)</div>
                        <div class="trend up">+@(Model?.NewPoliciesThisMonth ?? 0) this month</div>
                    </div>
                    <div class="card stat">
                        <div class="k">Expired</div>
                        <div class="v">@(Model?.ExpiredPoliciesCount ?? 0)</div>
                        <div class="trend down">Renew soon</div>
                    </div>
                    <div class="card stat">
                        <div class="k">Active Renewals</div>
                        <div class="v">@(Model?.ActiveRenewalsCount ?? 0)</div>
                        <div class="trend up">In progress</div>
                    </div>
                    <div class="card stat">
                        <div class="k">Pending Claims</div>
                        <div class="v">@(Model?.PendingClaimsCount ?? 0)</div>
                        <div class="trend">Avg @(Model?.AverageClaimProcessingDays ?? 0) days</div>
                    </div>
                    <div class="card stat">
                        <div class="k">Subscribed Services</div>
                        <div class="v">@(Model?.SubscribedServicesCount ?? 0)</div>
                        <div class="trend">Out of @(Model?.TotalProductsCount ?? 0)</div>
                    </div>
                    <div class="card stat">
                        <div class="k">Account Balance</div>
                        <div class="v">@(Model.AccountBalance.ToString("N2"))</div>
                        <div class="trend">@(Model?.Currency ?? "MZN")</div>
                    </div>
                </div>

                <!-- tables + actions -->
                <div class="grid2">
                    <div class="card">
                        <h3 style="margin:0 0 16px;color:var(--text);font-size:18px;">Recent Claims & Quotations</h3>
                        <table>
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Ref</th>
                                    <th>Status</th>
                                    <th>Updated</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.RecentClaimsQuotations != null)
                                {
                                    @foreach (var item in ViewBag.RecentClaimsQuotations)
                                    {
                                        <tr>
                                            <td>@item.Type</td>
                                            <td style="font-weight:500;">@item.Reference</td>
                                            <td><span class="pill @item.StatusClass">@item.Status</span></td>
                                            <td>@item.UpdatedDate.ToString("dd MMM")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" style="text-align:center;color:var(--muted);padding:30px;">
                                            No recent claims or quotations
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="card">
                        <h3 style="margin:0 0 16px;color:var(--text);font-size:18px;">Expiring Documents</h3>
                        <table>
                            <thead>
                                <tr>
                                    <th>Document</th>
                                    <th>Expires</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.ExpiringDocuments != null)
                                {
                                    @foreach (var doc in ViewBag.ExpiringDocuments)
                                    {
                                        <tr>
                                            <td style="font-weight:500;">@doc.Name</td>
                                            <td><span class="pill @doc.UrgencyClass">@doc.ExpiryDate.ToString("dd MMM yyyy")</span></td>
                                            <td><a class="btn-secondary" asp-controller="Policies" asp-action="Renew" asp-route-id="@doc.Id">Renew</a></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" style="text-align:center;color:var(--muted);padding:30px;">
                                            No expiring documents
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="grid2">
                    <div class="card">
                        <h3 style="margin:0 0 16px;color:var(--text);font-size:18px;">Register Interaction</h3>
                        <form asp-controller="Interactions" asp-action="Create" method="post">
                            <div style="display:grid;gap:12px;grid-template-columns:1fr 1fr;">
                                <input name="Subject" class="input" placeholder="Subject" style="grid-column:1/-1;" required />
                                <select name="Type" class="input" required>
                                    <option value="">Select Type</option>
                                    <option>Call</option>
                                    <option>Email</option>
                                    <option>Meeting</option>
                                    <option>Note</option>
                                </select>
                                <input name="When" type="datetime-local" class="input" required />
                                <textarea name="Notes" rows="3" class="input" placeholder="Notes…" style="grid-column:1/-1;"></textarea>
                            </div>
                            <div style="margin-top:16px;display:flex;gap:12px;">
                                <button class="btn-primary" type="submit">Save Interaction</button>
                                <a class="btn-secondary" asp-controller="Interactions" asp-action="Index">View All</a>
                            </div>
                        </form>
                    </div>

                    <div class="card actions">
                        <h3 style="margin:0 0 16px;color:var(--text);font-size:18px;">Statements & Downloads</h3>

                        <div class="item">
                            <div>
                                <strong>Account Statement</strong>
                                <div style="color:var(--muted);font-size:13px;margin-top:2px;">Monthly PDF</div>
                            </div>
                            <a class="btn-secondary" asp-controller="Statements" asp-action="Download" asp-route-type="Account">Download</a>
                        </div>

                        <div class="item">
                            <div>
                                <strong>Policy Schedule</strong>
                                <div style="color:var(--muted);font-size:13px;margin-top:2px;">Latest version</div>
                            </div>
                            <a class="btn-secondary" asp-controller="Statements" asp-action="Download" asp-route-type="Policy">Download</a>
                        </div>

                        <div class="item">
                            <div>
                                <strong>Claims Summary</strong>
                                <div style="color:var(--muted);font-size:13px;margin-top:2px;">This year</div>
                            </div>
                            <a class="btn-secondary" asp-controller="Statements" asp-action="Download" asp-route-type="Claims">Download</a>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Mobile toggle for sidebar (optional)
        (function(){
          const side = document.getElementById('side');
          const btn  = document.getElementById('sideToggle');
          if (btn) {
            btn.style.display = window.matchMedia('(max-width: 980px)').matches ? '' : 'none';
            btn.addEventListener('click', ()=> {
              const expanded = side.getAttribute('aria-expanded') !== 'false';
              side.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            });
            window.addEventListener('resize', () => {
              btn.style.display = window.matchMedia('(max-width: 980px)').matches ? '' : 'none';
              side.setAttribute('aria-expanded', 'true');
            });
          }
        })();
    </script>
}