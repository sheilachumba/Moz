@using ClientPortal.Models
@model ClientPortal.Models.ApplicationUser
@{
    ViewData["Title"] = "Company Dashboard";
    Layout = "_Layout";

    // helpers to read ViewBag safely
    int? ToInt(object o)
    {
        if (o == null) return null;
        if (o is int i) return i;
        if (o is long l) return (int)l;
        if (o is short s) return s;
        if (o is string str && int.TryParse(str, out var v)) return v;
        return null;
    }
    decimal? ToDec(object o)
    {
        if (o == null) return null;
        if (o is decimal d) return d;
        if (o is double db) return (decimal)db;
        if (o is float f) return (decimal)f;
        if (o is int i) return i;
        if (o is long l) return l;
        if (o is string str && decimal.TryParse(str, out var v)) return v;
        return null;
    }

    // resolve ViewBag values
    int? unread = ToInt(ViewBag.UnreadNotificationsCount ?? Model?.UnreadNotificationsCount);
    int? activePolicies = ToInt(ViewBag.ActivePoliciesCount ?? Model?.ActivePoliciesCount);
    int? expiredPolicies = ToInt(ViewBag.ExpiredPoliciesCount ?? Model?.ExpiredPoliciesCount);
    int? activeRenewals = ToInt(ViewBag.ActiveRenewalsCount ?? Model?.ActiveRenewalsCount);
    int? pendingClaims = ToInt(ViewBag.PendingClaimsCount ?? Model?.PendingClaimsCount);
    int? totalProducts = ToInt(ViewBag.TotalProductsCount ?? Model?.TotalProductsCount);
    int? subscribedServices = ToInt(ViewBag.SubscribedServicesCount ?? Model?.SubscribedServicesCount);
    int? newPoliciesThisMonth = ToInt(ViewBag.NewPoliciesThisMonth ?? Model?.NewPoliciesThisMonth);
    int? avgClaimDays = ToInt(ViewBag.AverageClaimProcessingDays ?? Model?.AverageClaimProcessingDays);
    decimal? accountBalance = ToDec(ViewBag.AccountBalance ?? Model?.AccountBalance);

    string currency = Model?.Currency;
    KycStatus? kycStatus = ViewBag.KycStatus as KycStatus? ?? Model?.KycStatus;
    string coverUrl = ViewBag.CoverUrl as string;
    var recentCQ = ViewBag.RecentClaimsQuotations as IEnumerable<ClaimQuotationVm>;
    var expiringDocs = ViewBag.ExpiringDocuments as IEnumerable<ExpiringDocumentVm>;

    var currentCtrl = (ViewContext?.RouteData?.Values["controller"] as string ?? "").ToLowerInvariant();
    Func<string, string> LinkClass = ctrl => currentCtrl == (ctrl ?? "").ToLowerInvariant() ? "link active" : "link";
}
<style>
    /* ===== Dashboard Theme (scoped with .dash) ===== */
    .dash {
        --brand: #1a2555; /* Deep navy blue */
        --brand-2: #2d3b8b; /* Medium blue */
        --brand-light: #4f63c1; /* Light blue */
        --bg: #f8fafc; /* Very light gray background */
        --card: #ffffff; /* White cards */
        --text: #0f172a; /* Near black for text */
        --text-muted: #334155; /* Dark gray */
        --muted: #64748b; /* Medium gray */
        --muted-light: #cbd5e1; /* Light gray */
        --ok: #059669; /* Green */
        --warn: #d97706; /* Amber */
        --bad: #dc2626; /* Red */
        --border: #e2e8f0; /* Light border */
        --ring: #3b82f6; /* Blue ring */
        --radius: 12px;
        --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
        --shadow-lg: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

        .dash * {
            box-sizing: border-box;
        }

        .dash .wrap {
            max-width: 1280px;
            margin: 0 auto;
            padding: 24px 16px 60px;
            background: var(--bg);
        }

        .dash h1 {
            margin: 0;
            color: var(--brand);
            font-weight: 800;
            font-size: clamp(24px, 2.5vw, 32px);
            font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        }

        .dash .sub {
            color: var(--muted);
            margin-top: 6px;
            font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        }

        /* ===== Shell: sidebar + main ===== */
        .dash .shell {
            display: grid;
            gap: 24px;
            grid-template-columns: 260px 1fr;
            align-items: start;
            font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        }

    @@media (max-width: 980px) {
        .dash .shell {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }

    /* ===== Sidebar ===== */
    .dash .side {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        position: sticky;
        top: 16px;
        overflow: hidden;
    }

        .dash .side .hd {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            font-weight: 700;
            color: var(--brand);
            background: var(--bg);
            font-size: 16px;
            font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        }

        .dash .side nav {
            padding: 12px 8px;
        }

    .dash .link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        font-size: 14px;
        transition: all 0.2s ease;
        margin: 4px 0;
    }

        .dash .link:hover {
            background: #f1f5f9;
            color: var(--brand);
        }

        .dash .link.active {
            background: var(--brand);
            color: white;
            font-weight: 600;
        }

    .dash .sep {
        height: 1px;
        background: var(--border);
        margin: 8px 12px;
    }

    @@media (max-width: 980px) {
        .dash .side {
            position: static;
        }

            .dash .side .hd {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .dash .side[aria-expanded="false"] nav {
                display: none;
            }
    }

    /* ===== Header row inside main ===== */
    .dash .hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
        padding: 0 4px;
    }

        .dash .hdr .right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

    .dash .notif {
        position: relative;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--card);
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .dash .notif:hover {
            border-color: var(--brand-light);
            box-shadow: var(--shadow);
        }

        .dash .notif .badge {
            position: absolute;
            right: -4px;
            top: -4px;
            background: var(--bad);
            color: white;
            font-size: 11px;
            border-radius: 999px;
            padding: 2px 6px;
            line-height: 1;
            font-weight: 600;
            min-width: 18px;
            text-align: center;
        }

    /* ===== Hero Section ===== */
    .dash .hero-container {
        background: linear-gradient(135deg, var(--brand) 0%, var(--brand-2) 100%);
        border-radius: var(--radius);
        overflow: hidden;
        margin-bottom: 20px;
        box-shadow: var(--shadow-lg);
        position: relative;
    }

    .dash .hero-content {
        padding: 40px 32px;
        color: white;
        position: relative;
        z-index: 2;
    }

        .dash .hero-content h2 {
            font-size: 28px;
            font-weight: 700;
            margin: 0 0 12px 0;
            color: white;
        }

        .dash .hero-content p {
            font-size: 16px;
            margin: 0 0 24px 0;
            opacity: 0.9;
            max-width: 500px;
        }

    .dash .hero-image {
        position: absolute;
        right: 0;
        top: 0;
        height: 100%;
        width: 40%;
        object-fit: cover;
        border-radius: 0 var(--radius) var(--radius) 0;
    }

    @@media (max-width: 768px) {
        .dash .hero-image {
            width: 100%;
            opacity: 0.2;
            border-radius: var(--radius);
        }

        .dash .hero-content {
            padding: 32px 24px;
        }
    }

    .dash .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: white;
        color: var(--brand);
        text-decoration: none;
        border-radius: 8px;
        padding: 12px 20px;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

        .dash .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        }

    /* ===== Welcome Bar ===== */
    .dash .welcome-bar {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 24px;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--shadow);
    }

    .dash .welcome-text {
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
    }

        .dash .welcome-text strong {
            font-size: 18px;
            color: var(--text);
            display: block;
            margin-bottom: 4px;
        }

        .dash .welcome-text span {
            color: var(--muted);
            font-size: 14px;
        }

    /* ===== Stat cards ===== */
    .dash .stats {
        margin-top: 0;
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
    }

    @@media (max-width: 1200px) {
        .dash .stats {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .dash .stats {
            grid-template-columns: 1fr;
        }
    }

    .dash .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        box-shadow: var(--shadow);
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .dash .card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

    .dash .stat .k {
        font-size: 13px;
        color: var(--muted);
        font-weight: 500;
        margin-bottom: 8px;
    }

    .dash .stat .v {
        font-size: 24px;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 4px;
    }

    .dash .trend {
        font-size: 12px;
        font-weight: 500;
    }

        .dash .trend.up {
            color: var(--ok);
        }

        .dash .trend.down {
            color: var(--bad);
        }

    /* ===== 2-col sections ===== */
    .dash .grid2 {
        margin-top: 24px;
        display: grid;
        gap: 20px;
        grid-template-columns: 1fr 1fr;
    }

    @@media (max-width: 980px) {
        .dash .grid2 {
            grid-template-columns: 1fr;
        }
    }

    .dash table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    .dash thead th {
        text-align: left;
        color: var(--muted);
        font-weight: 600;
        font-size: 12px;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .dash tbody td {
        padding: 16px;
        border-bottom: 1px solid var(--border);
        color: var(--text-muted);
    }

    .dash tbody tr:last-child td {
        border-bottom: none;
    }

    .dash tbody tr:hover {
        background: var(--bg);
    }

    .dash .pill {
        font-size: 11px;
        border-radius: 999px;
        padding: 4px 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

        .dash .pill.ok {
            background: #f0fdf4;
            color: var(--ok);
            border: 1px solid #bbf7d0;
        }

        .dash .pill.bad {
            background: #fef2f2;
            color: var(--bad);
            border: 1px solid #fecaca;
        }

        .dash .pill.warn {
            background: #fffbeb;
            color: var(--warn);
            border: 1px solid #fed7aa;
        }

        .dash .pill.neutral {
            background: #f8fafc;
            color: var(--muted);
            border: 1px solid var(--border);
        }

    /* ===== Actions list ===== */
    .dash .actions .item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px;
        background: var(--card);
        transition: all 0.2s ease;
    }

        .dash .actions .item:hover {
            border-color: var(--brand-light);
            box-shadow: var(--shadow);
        }

        .dash .actions .item + .item {
            margin-top: 12px;
        }

    .dash .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--card);
        border: 1px solid var(--border);
        color: var(--brand);
        text-decoration: none;
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 500;
        transition: all 0.2s ease;
        white-space: nowrap;
    }

        .dash .btn-secondary:hover {
            background: var(--brand);
            color: white;
            border-color: var(--brand);
        }

    /* KYC Status Banner */
    .kyc-status-banner {
        padding: 16px 20px;
        border-radius: var(--radius);
        margin-bottom: 20px;
        font-weight: 600;
        border: 1px solid;
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .kyc-status-pending {
        background-color: #fffbeb;
        color: #92400e;
        border-color: #fcd34d;
    }

    .kyc-status-approved {
        background-color: #f0fdf4;
        color: #166534;
        border-color: #86efac;
    }

    /* Form Styles */
    .dash .input {
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 10px 12px;
        font-family: "Segoe UI", "Roboto", "Helvetica Neue", Arial, sans-serif;
        font-size: 14px;
        transition: border-color 0.2s ease;
        background: var(--card);
    }

        .dash .input:focus {
            outline: none;
            border-color: var(--brand-light);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

    .dash textarea.input {
        resize: vertical;
        min-height: 80px;
    }
</style>

<section class="dash">
    <div class="wrap">
        <div class="shell">

            <!-- SIDEBAR -->
            <aside class="side" id="side" aria-expanded="true">
                <div class="hd">
                    Menu
                    <button class="btn-secondary" id="sideToggle" style="display:none;">Toggle</button>
                </div>
                <nav>
                    <a class="@LinkClass("Dashboard")" asp-area="" asp-controller="Dashboard" asp-action="Company">Overview</a>
                    <a class="@LinkClass("Policies")" asp-area="" asp-controller="Policies" asp-action="Index">Policies</a>
                    <a class="@LinkClass("Renewals")" asp-area="" asp-controller="Renewals" asp-action="Index">Renewals</a>
                    <a class="@LinkClass("Claims")" asp-area="" asp-controller="Claims" asp-action="Index">Claims</a>
                    <a class="@LinkClass("Quotations")" asp-area="" asp-controller="Quotations" asp-action="Index">Quotations</a>
                    <a class="@LinkClass("Interactions")" asp-area="" asp-controller="Interactions" asp-action="Index">Interactions</a>
                    <div class="sep"></div>
                    <a class="@LinkClass("Products")" asp-area="" asp-controller="Products" asp-action="Index">Products & Services</a>
                    <a class="@LinkClass("Documents")" asp-area="" asp-controller="Documents" asp-action="Index">Documents</a>
                    <a class="@LinkClass("Statements")" asp-area="" asp-controller="Statements" asp-action="Index">Statements</a>

                    <div class="sep"></div>
                    <a class="@LinkClass("Settings")" asp-area="" asp-controller="Settings" asp-action="Index">Settings</a>
                </nav>
            </aside>

            <!-- MAIN -->
            <main>
                <!-- header row: title + notifications -->
                <div class="hdr">
                    <div>
                        <h1>Company Dashboard</h1>
                        <div class="sub">Overview of your policies, claims, renewals and documents</div>
                    </div>
                    <div class="right">
                        <a class="notif" asp-controller="Notifications" asp-action="Index" title="Notifications">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14v-2a6 6 0 1 0-12 0v2c0 .5-.2 1-.6 1.4L4 17h5" />
                                <path d="M9 20a3 3 0 0 0 6 0" />
                            </svg>
                            @if (unread.GetValueOrDefault() > 0)
                            {
                                <span class="badge">@unread</span>
                            }
                        </a>
                    </div>
                </div>

                <!-- KYC Status Banner -->
                @if (kycStatus == KycStatus.Submitted)
                {
                    <div class="kyc-status-banner kyc-status-pending">
                        <i class="bi bi-clock-history"></i> Your Company KYC application is under review
                    </div>
                }
                else if (kycStatus == KycStatus.Verified)
                {
                    <div class="kyc-status-banner kyc-status-approved">
                        <i class="bi bi-check-circle"></i> Your Company KYC has been approved!
                    </div>
                }

                <!-- Hero Section -->
                <div class="hero-container">
                    <div class="hero-content">
                        <h2>Company Dashboard</h2>
                        // <p>Manage your corporate insurance policies, track claims, and access all business documents in one place.</p>
                        <a href="#" class="btn-primary">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 5v14m-7-7h14" />
                            </svg>
                            Get Started
                        </a>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(coverUrl))
                    {
                        <img src="@coverUrl" alt="Company Dashboard" class="hero-image" onerror="this.style.display='none'" />
                    }
                    else
                    {
                        <img src="~/images/kyc-banner.png" alt="Company Dashboard" class="hero-image" onerror="this.style.display='none'" />
                    }
                </div>

                <!-- Welcome Bar -->
                <div class="welcome-bar">
                    <div class="welcome-text">
                        @if (!string.IsNullOrWhiteSpace(Model?.CompanyName))
                        {
                            <strong>Welcome, @Model.CompanyName</strong>
                        }
                        else
                        {
                            <strong>Welcome to Company Dashboard</strong>
                        }
                        <span>Manage policies, claims, renewals and downloads from one place.</span>
                    </div>
                    <div>
                        @if (kycStatus == KycStatus.Submitted || kycStatus == KycStatus.Verified || (Model?.KycCompleted ?? false))
                        {
                            <div class="kyc-status-banner kyc-status-approved" style="margin:0; padding: 8px 12px; font-size: 13px;">
                                <i class="bi bi-check-circle"></i> KYC Submitted - Application Under Review
                            </div>
                        }
                    </div>
                </div>

                <!-- stats -->
                <div class="stats">
                    @if (activePolicies.HasValue)
                    {
                        <div class="card stat">
                            <div class="k">Active Policies</div>
                            <div class="v">@activePolicies</div>
                            @if (newPoliciesThisMonth.HasValue)
                            {
                                <div class="trend up">+@newPoliciesThisMonth this month</div>
                            }
                        </div>
                    }
                    @if (expiredPolicies.HasValue)
                    {
                        <div class="card stat">
                            <div class="k">Expired</div>
                            <div class="v">@expiredPolicies</div>
                            <div class="trend down">Renew soon</div>
                        </div>
                    }
                    @if (activeRenewals.HasValue)
                    {
                        <div class="card stat">
                            <div class="k">Active Renewals</div>
                            <div class="v">@activeRenewals</div>
                            <div class="trend up">In progress</div>
                        </div>
                    }
                    @if (pendingClaims.HasValue)
                    {
                        <div class="card stat">
                            <div class="k">Pending Claims</div>
                            <div class="v">@pendingClaims</div>
                            @if (avgClaimDays.HasValue)
                            {
                                <div class="trend">Avg @avgClaimDays days</div>
                            }
                        </div>
                    }
                    @if (totalProducts.HasValue)
                    {
                        <div class="card stat">
                            <div class="k">Total Products</div>
                            <div class="v">@totalProducts</div>
                            @if (subscribedServices.HasValue)
                            {
                                <div class="trend">Subscribed: @subscribedServices</div>
                            }
                        </div>
                    }
                    @if (accountBalance.HasValue)
                    {
                        <div class="card stat">
                            <div class="k">Account Balance</div>
                            <div class="v">@((Model?.AccountBalance ?? 0m).ToString("N2"))</div>
                            @if (!string.IsNullOrWhiteSpace(currency))
                            {
                                <div class="trend">@currency</div>
                            }
                        </div>
                    }
                </div>

                <!-- tables + actions -->
                @if ((recentCQ != null && recentCQ.Any()) || (expiringDocs != null && expiringDocs.Any()))
                {
                    <div class="grid2">
                        @if (recentCQ != null && recentCQ.Any())
                        {
                            <div class="card">
                                <h3 style="margin:0 0 16px;color:var(--text);font-size:18px;">Recent Claims & Quotations</h3>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Type</th>
                                            <th>Ref</th>
                                            <th>Status</th>
                                            <th>Updated</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in recentCQ)
                                        {
                                            <tr>
                                                <td>@item.Type</td>
                                                <td style="font-weight:500;">@item.Reference</td>
                                                <td><span class="pill @item.StatusClass">@item.Status</span></td>
                                                <td>@(((DateTime)item.UpdatedDate).ToString("dd MMM"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        @if (expiringDocs != null && expiringDocs.Any())
                        {
                            <div class="card">
                                <h3 style="margin:0 0 16px;color:var(--text);font-size:18px;">Expiring Documents</h3>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Document</th>
                                            <th>Expires</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var doc in expiringDocs)
                                        {
                                            <tr>
                                                <td style="font-weight:500;">@doc.Name</td>
                                                <td><span class="pill @doc.UrgencyClass">@(((DateTime)doc.ExpiryDate).ToString("dd MMM yyyy"))</span></td>
                                                <td><a class="btn-secondary" asp-controller="Policies" asp-action="Renew" asp-route-id="@doc.Id">Renew</a></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }

                <!-- actions block -->
                <div class="grid2">
                    <div class="card">
                        <h3 style="margin:0 0 16px;color:var(--text);font-size:18px;">Register Interaction</h3>
                        <form asp-controller="Interactions" asp-action="Create" method="post">
                            <div style="display:grid;gap:12px;grid-template-columns:1fr 1fr;">
                                <input name="Subject" class="input" placeholder="Subject" style="grid-column:1/-1;" required />
                                <select name="Type" class="input" required>
                                    <option value="">Select Type</option>
                                    <option>Call</option>
                                    <option>Email</option>
                                    <option>Meeting</option>
                                    <option>Note</option>
                                </select>
                                <input name="When" type="datetime-local" class="input" required />
                                <textarea name="Notes" rows="3" class="input" placeholder="Notes…" style="grid-column:1/-1;"></textarea>
                            </div>
                            <div style="margin-top:16px;display:flex;gap:12px;">
                                <button class="btn-primary" type="submit">Save Interaction</button>
                                <a class="btn-secondary" asp-controller="Interactions" asp-action="Index">View All</a>
                            </div>
                        </form>
                    </div>

                    <div class="card actions">
                        <h3 style="margin:0 0 16px;color:var(--text);font-size:18px;">Statements & Downloads</h3>

                        <div class="item">
                            <div>
                                <strong>Account Statement</strong>
                                <div style="color:var(--muted);font-size:13px;margin-top:2px;">Monthly PDF</div>
                            </div>
                            <a class="btn-secondary" asp-controller="Statements" asp-action="Download" asp-route-type="Account">Download</a>
                        </div>

                        <div class="item">
                            <div>
                                <strong>Policy Schedule</strong>
                                <div style="color:var(--muted);font-size:13px;margin-top:2px;">Latest version</div>
                            </div>
                            <a class="btn-secondary" asp-controller="Statements" asp-action="Download" asp-route-type="Policy">Download</a>
                        </div>

                        <div class="item">
                            <div>
                                <strong>Claims Summary</strong>
                                <div style="color:var(--muted);font-size:13px;margin-top:2px;">This year</div>
                            </div>
                            <a class="btn-secondary" asp-controller="Statements" asp-action="Download" asp-route-type="Claims">Download</a>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Mobile toggle for sidebar
        (function(){
          const side = document.getElementById('side');
          const btn  = document.getElementById('sideToggle');
          if (!side || !btn) return;
          function sync() {
            btn.style.display = window.matchMedia('(max-width: 980px)').matches ? '' : 'none';
            side.setAttribute('aria-expanded', 'true');
          }
          btn.addEventListener('click', ()=> {
            const expanded = side.getAttribute('aria-expanded') !== 'false';
            side.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          });
          window.addEventListener('resize', sync);
          sync();
        })();
    </script>
}