@page "/reset-password/{Token}"
@layout HomeLayout
@inject MOZ_UPGRADE.Interfaces.IUnitOfWork unitOfWork
@inject NavigationManager NavigationManager
@inject MOZ_UPGRADE.Utils.LanguageService LangService
@inject MudBlazor.ISnackbar Snackbar

<style>
    .reset-header-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        padding: 16px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        z-index: 100;
    }

    .reset-header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .reset-header-logo {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #FF9900 0%, #E68A00 100%);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .reset-header-logo img {
        width: 32px;
        height: 32px;
        object-fit: contain;
    }

    .reset-header-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
        color: #003366;
    }

    .reset-header-title {
        font-size: 14px;
        font-weight: 600;
    }

    .reset-header-subtitle {
        font-size: 12px;
        opacity: 0.7;
    }

    .reset-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f5f7;
        padding: 96px 16px 40px 16px;
    }

    .reset-card {
        max-width: 420px;
        width: 100%;
        background: #ffffff;
        border-radius: 18px;
        padding: 28px 24px 24px 24px;
        box-shadow: 0 18px 45px rgba(15,23,42,0.16);
    }

    .reset-header {
        text-align: center;
        margin-bottom: 18px;
    }

    .reset-title {
        font-size: 22px;
        font-weight: 700;
        color: #003366;
        margin-bottom: 6px;
    }

    .reset-subtitle {
        font-size: 13px;
        color: #6b7280;
    }

    .reset-form-group {
        margin-top: 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .reset-label {
        font-size: 12px;
        font-weight: 600;
        color: #17275F;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .reset-message {
        margin-top: 10px;
        padding: 10px 12px;
        border-radius: 8px;
        font-size: 13px;
    }

    .reset-message-error {
        background-color: #fee2e2;
        color: #b91c1c;
    }

    .reset-message-success {
        background-color: #dcfce7;
        color: #166534;
    }

    .reset-actions {
        display: flex;
        gap: 10px;
        margin-top: 18px;
    }

    .reset-button-primary {
        flex: 1;
        background: linear-gradient(135deg, #283A79 0%, #283A79 100%);
        color: white;
        padding: 11px 18px;
        border: none;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
    }

    .reset-button-secondary {
        flex: 1;
        background: #ffffff;
        color: #17275F;
        border: 2px solid #17275F;
        padding: 11px 18px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
    }

    .reset-button-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
</style>
<div class="reset-header-bar">
    <div class="reset-header-left">
        <div class="reset-header-logo">
            <img src="/images/logo.png" alt="STANDARD INSURANCE" />
        </div>
        <div class="reset-header-text">
            <div class="reset-header-title">Standard Insurance</div>
            <div class="reset-header-subtitle">@LangService.T("Password Recovery","Recuperação de Palavra-passe")</div>
        </div>
    </div>
</div>

<div class="reset-container">
    <div class="reset-card">
        <div class="reset-header">
            <div class="reset-title">@LangService.T("Reset Password","Redefinir Palavra-passe")</div>
            <div class="reset-subtitle">
                @if (string.IsNullOrEmpty(errorMessage))
                {
                    @LangService.T("Choose a new password for your account.","Escolha uma nova palavra-passe para a sua conta.")
                }
                else
                {
                    @errorMessage
                }
            </div>
        </div>

        @if (!invalidToken)
        {
            <EditForm Model="@model" OnValidSubmit="OnSubmitAsync">
                <DataAnnotationsValidator />

                <div class="reset-form-group">
                    <label class="reset-label">@LangService.T("New Password","Nova Palavra-passe")</label>
                    <MudTextField @bind-Value="model.Password"
                                  For="@(() => model.Password)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  InputType="@passwordInputType"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@passwordIcon"
                                  OnAdornmentClick="TogglePasswordVisibility" />
                </div>

                <div class="reset-form-group">
                    <label class="reset-label">@LangService.T("Confirm Password","Confirmar Palavra-passe")</label>
                    <MudTextField @bind-Value="model.ConfirmPassword"
                                  For="@(() => model.ConfirmPassword)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  InputType="@confirmPasswordInputType"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@confirmPasswordIcon"
                                  OnAdornmentClick="ToggleConfirmPasswordVisibility" />
                </div>

                @if (!string.IsNullOrWhiteSpace(infoMessage))
                {
                    <div class="reset-message @(success ? "reset-message-success" : "reset-message-error")">
                        @infoMessage
                    </div>
                }

                <div class="reset-actions">
                    <button type="button" class="reset-button-secondary" @onclick="GoToLogin">@LangService.T("Back to login","Voltar ao login")</button>
                    <button type="submit" class="reset-button-primary" disabled="@(saving || success)">
                        @(saving ? LangService.T("Saving...","A guardar...") : LangService.T("Reset password","Redefinir palavra-passe"))
                    </button>
                </div>
            </EditForm>
        }
        else
        {
            <div class="reset-message reset-message-error">
                @errorMessage
            </div>

            <div class="reset-actions">
                <button type="button" class="reset-button-primary" @onclick="GoToLogin">@LangService.T("Back to login","Voltar ao login")</button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string Token { get; set; }

    private ResetPasswordModel model = new ResetPasswordModel();
    private bool invalidToken = false;
    private string decryptedEmail = string.Empty;
    private string errorMessage = string.Empty;
    private string infoMessage = string.Empty;
    private bool success = false;
    private bool saving = false;

    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private InputType passwordInputType => showPassword ? InputType.Text : InputType.Password;
    private string passwordIcon => showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private InputType confirmPasswordInputType => showConfirmPassword ? InputType.Text : InputType.Password;
    private string confirmPasswordIcon => showConfirmPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(Token))
            {
                invalidToken = true;
                errorMessage = "Invalid or missing reset link.";
                return;
            }

            var decoded = System.Net.WebUtility.UrlDecode(Token);
            var encryption = new MOZ_UPGRADE.Utils.Encryption();
            decryptedEmail = encryption.Decryptedstring(decoded);

            if (string.IsNullOrWhiteSpace(decryptedEmail))
            {
                invalidToken = true;
                errorMessage = "Invalid reset link.";
                return;
            }

            var user = await unitOfWork.userRepository.FindUserwithMail(decryptedEmail);
            if (user == null)
            {
                invalidToken = true;
                errorMessage = "The account for this link could not be found.";
                return;
            }
        }
        catch
        {
            invalidToken = true;
            errorMessage = "The reset link is invalid or has expired.";
        }
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        showConfirmPassword = !showConfirmPassword;
    }

    private async Task OnSubmitAsync()
    {
        infoMessage = string.Empty;
        success = false;

        if (string.IsNullOrWhiteSpace(model.Password) || string.IsNullOrWhiteSpace(model.ConfirmPassword))
        {
            infoMessage = "Please enter and confirm your new password.";
            success = false;
            return;
        }

        if (model.Password != model.ConfirmPassword)
        {
            infoMessage = "Passwords do not match.";
            success = false;
            return;
        }

        if (model.Password.Length < 8)
        {
            infoMessage = "Password must be at least 8 characters long.";
            success = false;
            return;
        }

        saving = true;

        try
        {
            var user = await unitOfWork.userRepository.FindUserwithMail(decryptedEmail);
            if (user == null)
            {
                infoMessage = "The account for this link could not be found.";
                success = false;
                return;
            }

            var encryption = new MOZ_UPGRADE.Utils.Encryption();
            user.password_hash = encryption.Encryptstring(model.Password);

            await unitOfWork.userRepository.Update(user);

            success = true;
            infoMessage = "Your password has been reset successfully.";
            Snackbar.Add("Password reset successfully. You can now login with your new password.", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            infoMessage = $"Failed to reset password: {ex.Message}";
            success = false;
        }
        finally
        {
            saving = false;
        }
    }

    private void GoToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }

    public class ResetPasswordModel
    {
        [Required(ErrorMessage = "Required Field")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters long")]
        public string Password { get; set; }

        [Required(ErrorMessage = "Required Field")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")] 
        public string ConfirmPassword { get; set; }
    }
}
