    // Method to check password requirements as user types
    private void OnPasswordChanged(string password)
    {
        if (password != null)
        {
            UpdatePasswordRequirements(password);
            StateHasChanged();
        }
    }

    // Update password requirements based on input
    private void UpdatePasswordRequirements(string password)
    {
        passwordRequirements.MinLength = password.Length >= 8;
        passwordRequirements.HasLowercase = System.Text.RegularExpressions.Regex.IsMatch(password, "[a-z]");
        passwordRequirements.HasUppercase = System.Text.RegularExpressions.Regex.IsMatch(password, "[A-Z]");
        passwordRequirements.HasNumber = System.Text.RegularExpressions.Regex.IsMatch(password, "[0-9]");
        passwordRequirements.HasSymbol = System.Text.RegularExpressions.Regex.IsMatch(password, "[!@#$%^&*()_+\\-=\\[\\]{};':\"\\\\|,.<>\\/?]");
    }

    // Class to track password requirements
    private class PasswordRequirements
    {
        public bool MinLength { get; set; }
        public bool HasLowercase { get; set; }
        public bool HasUppercase { get; set; }
        public bool HasNumber { get; set; }
        public bool HasSymbol { get; set; }
    }
    bool Basic_CheckBox2 = false;
    private bool isAuthenticated = false;
    private string? _returnUrl;
    protected override async Task OnInitializedAsync()
    {

        HttpContextAccessor.HttpContext.Session.SetString("developer_kili", "kili");
        // Capture returnUrl from query if present
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("returnUrl", out var rv))
        {
            _returnUrl = rv.FirstOrDefault();
        }


        await UpdateAuthState();
    }

    protected void GoToCreate()
    {
        // CreateAccount
        navigate.NavigateTo("/CreateAccount");
    }
    private bool showForgotPassword = false;

    private ForgotPasswordModel forgotModel = new ForgotPasswordModel();
    private string forgotMessage = string.Empty;
    private bool forgotSuccess = false;
    private bool forgotLoading = false;

    protected void OpenForgotPassword()
    {
        forgotModel = new ForgotPasswordModel();
        forgotMessage = string.Empty;
        forgotSuccess = false;
        forgotLoading = false;
        showForgotPassword = true;
    }

    protected void CloseForgotPassword()
    {
        showForgotPassword = false;
    }

    bool isShow;
    InputType PasswordInput = InputType.Password;
    string PasswordInputIcon = Icons.Material.Filled.VisibilityOff;

    void ButtonTestclick()
    {
        if (isShow)
        {
            isShow = false;
            PasswordInputIcon = Icons.Material.Filled.VisibilityOff;
            PasswordInput = InputType.Password;
        }
        else
        {
            isShow = true;
            PasswordInputIcon = Icons.Material.Filled.Visibility;
            PasswordInput = InputType.Text;
        }
    }

    private bool isloading = false;
    loginDetails users = new loginDetails();
    private async Task OnValidSubmit(EditContext context)
    {
        isloading = true;

        // try
        // {
        // Step 1: Validate credentials FIRST (quick operation)
        TokenProvider TokenProvider = new TokenProvider(unitOfWork, HttpContextAccessor);
        EmailSendStatus userToken = await TokenProvider.LoginUser(users.username, users.password);

        if (userToken.status == true)
        {
            // Step 2: Get user data (for 2FA and email verification checks)
            var user = await unitOfWork.userRepository.GetByEmail(users.username);

            // Step 3: Check if email is verified
            if (user != null && !user.IsEmailVerified)
            {
                isloading = false;
                StateHasChanged();
                Snackbar.Add("📧 Please verify your email address before logging in. Check your inbox for the verification link.", Severity.Warning);
                return;
            }

            // Step 4: Check if user has 2FA enabled
            if (user != null && user.IsTwoFAEnabled)
            {
                // 2FA is enabled - send verification code
                twoFAUsername = users.username;
                twoFAPassword = users.password;
                twoFAEmail = users.username;

                // Generate 2FA code
                twoFAStoredCode = unitOfWork.TwoFactorAuthService.GenerateCode();
                twoFACodeExpiry = unitOfWork.TwoFactorAuthService.GetExpiryTime();

                // Show 2FA modal immediately
                show2FA = true;
                twoFACode = new char[] { ' ', ' ', ' ', ' ', ' ', ' ' };
                twoFAMessage = "";

                isloading = false;

                // Send 2FA code via email (non-blocking, happens in background)
                Snackbar.Add("📧 Sending verification code to your email...", Severity.Info);
                _ = Task.Run(async () =>
                {
                    bool emailSent = await unitOfWork.EmailService.SendCodeAsync(users.username, twoFAStoredCode, users.username.Split('@')[0]);
                    if (emailSent)
                    {
                        await InvokeAsync(() => 
                        {
                            Snackbar.Add("✅ Verification code sent! Check your inbox.", Severity.Success);
                        });
                    }
                    else
                    {
                        await InvokeAsync(() => 
                        {
                            Snackbar.Add("Failed to send verification code. Please try again.", Severity.Error);
                        });
                    }
                });
            }
            else
            {
                // 2FA is disabled - login directly
                isloading = false;
                Snackbar.Add("Login successful", Severity.Success);
                NavigateToReturnUrlOrDashboard();
            }
        }
        else
        {
            // Invalid credentials
            isloading = false;
            Snackbar.Add(userToken.message, Severity.Error);
        }
        // }
        // catch (Exception ex)
        // {
        //     Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        // }
    }

    private async Task OnValidCreateAccount()
    {
        // Validate password confirmation
        if (user.password_hash != confirmPassword)
        {
            Snackbar.Add("❌ Passwords do not match", Severity.Error);
            return;
        }

        Encryption encryption = new Encryption();
        try
        {
            Layout.OpenLoading();

            user.Email = user.Email?.Trim();
            if (string.IsNullOrWhiteSpace(user.Email))
            {
                Snackbar.Add("❌ Email is required", Severity.Error);
                return;
            }

            var existingUser = await unitOfWork.userRepository.GetByEmail(user.Email);
            if (existingUser != null)
            {
                Snackbar.Add("Oops! This Email is already taken. Try a different one and make it yours!", Severity.Error);
                return;
            }

            // Set FullName depending on AccountType
            if (IsCorporateOrAssociation)
            {
                user.FullName = user.CompanyName?.Trim();
            }
            else
            {
                user.FullName = $"{user.FirstName} {user.MiddleName} {user.LastName}".Trim();
            }

            if (string.IsNullOrWhiteSpace(user.strid))
            {
                user.strid = Guid.NewGuid().ToString("N");
            }

            user.password_hash = encryption.Encryptstring(user.password_hash);
            user.EmailVerificationTimestamp = DateTime.UtcNow;

            await unitOfWork.userRepository.AddNew(user);
            unitOfWork.save();

            // Generate verification link with only the user ID
            string verificationLink = $"{NavigationManager.BaseUri}verify-email/{Uri.EscapeDataString(user.strid)}";

            // Send verification email
            bool emailSent = await EmailService.SendVerificationEmailAsync(user.Email, user.FullName ?? user.Email, verificationLink);

            if (emailSent)
            {
                Snackbar.Add("✅ Account created successfully! We've sent a verification link to your email — please check your inbox to activate your account.", Severity.Success);
            }
            else
            {
                Snackbar.Add("⚠️ Account created, but we couldn't send the verification email. Please contact support.", Severity.Warning);
            }

            close_Create_nav();
            showRegistration = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            Layout.CloseLoading();
        }
    }



    private async Task UpdateAuthState()
    {
        HttpContextAccessor.HttpContext.Session.SetString("developer_kili", "kili");
        var authState = await CustomAuthenticationStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity.IsAuthenticated;

        StateHasChanged();
    }

    private async Task SubmitForgotPassword()
    {
        forgotLoading = true;
        forgotMessage = string.Empty;
        forgotSuccess = false;

        try
        {
            var email = forgotModel.Email?.Trim();
            if (string.IsNullOrWhiteSpace(email))
            {
                forgotMessage = "Please enter your email address.";
                forgotSuccess = false;
                return;
            }

            var user = await unitOfWork.userRepository.FindUserwithMail(email);
            if (user == null)
            {
                forgotMessage = "The user with that email does not exist in our system.";
                forgotSuccess = false;
                return;
            }

            var encryption = new MOZ_UPGRADE.Utils.Encryption();
            var encryptedEmail = encryption.Encryptstring(email);
            var token = System.Net.WebUtility.UrlEncode(encryptedEmail);

            var resetLink = $"{NavigationManager.BaseUri}reset-password/{token}";

            var fullName = string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName;
            bool sent = await unitOfWork.EmailService.SendPasswordResetEmailAsync(email, fullName, resetLink);

            if (sent)
            {
                forgotMessage = "A reset link has been sent to your email.";
                forgotSuccess = true;
            }
            else
            {
                forgotMessage = "Failed to send reset email. Please try again later.";
                forgotSuccess = false;
            }
        }
        catch (Exception ex)
        {
            forgotMessage = $"Error while processing request: {ex.Message}";
            forgotSuccess = false;
        }
        finally
        {
            forgotLoading = false;
        }
    }


    public class loginDetails
    {
        [Required(ErrorMessage = "Required Field")]
        [EmailAddress(ErrorMessage = "Invalid email")]

        public string username { get; set; }
        [Required(ErrorMessage = "Required Field")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters long")]
        public string password { get; set; }
    }

    public class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Required Field")]
        [EmailAddress(ErrorMessage = "Invalid email")]
        public string Email { get; set; }
    }

    // 2FA Variables
    private bool show2FA = false;
    private string twoFAEmail = "";
    private char[] twoFACode = new char[] { ' ', ' ', ' ', ' ', ' ', ' ' };
    private string twoFAStoredCode = "";
    private DateTime twoFACodeExpiry;
    private string twoFAMessage = "";
    private bool twoFASuccess = false;
    private bool twoFAVerifying = false;
    private bool twoFAResendDisabled = false;
    private int twoFAResendTimer = 60;
    private string twoFAUsername = "";
    private string twoFAPassword = "";
    private ElementReference[] codeInputRefs = new ElementReference[6];

    private bool twoFAFocused = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (show2FA && !twoFAFocused)
        {
            // Focus on first input when 2FA modal opens
            twoFAFocused = true;
            try
            {
                await codeInputRefs[0].FocusAsync();
            }
            catch { }
        }
        else if (!show2FA)
        {
            twoFAFocused = false;
        }
    }

    private bool IsCodeComplete()
    {
        return twoFACode.All(c => c != ' ');
    }

    private async Task HandleCodeKeyDown(KeyboardEventArgs e, int index)
    {
        if (e.Key == "Backspace" && twoFACode[index] == ' ' && index > 0)
        {
            // Move focus to previous input on backspace if current is empty
            await codeInputRefs[index - 1].FocusAsync();
        }
    }

    private void HandleCodeChange(ChangeEventArgs e, int index)
    {
        string value = e.Value?.ToString() ?? "";
        if (value.Length > 0 && char.IsDigit(value[0]))
        {
            twoFACode[index] = value[0];
            StateHasChanged();
        }
    }

    private async Task HandleCodeKeyUp(KeyboardEventArgs e, int index)
    {
        // Only allow numbers
        if (e.Key.Length == 1 && char.IsDigit(e.Key[0]))
        {
            twoFACode[index] = e.Key[0];
            
            // Auto-focus to next input
            if (index < 5)
            {
                await codeInputRefs[index + 1].FocusAsync();
            }
            StateHasChanged();
        }
        else if (e.Key == "Backspace")
        {
            twoFACode[index] = ' ';
            StateHasChanged();
        }
    }

    private async Task HandlePaste(ClipboardEventArgs e)
    {
        // Paste handling will be done via JavaScript interop if needed
        // For now, users can paste one digit at a time
        await Task.CompletedTask;
    }

    private async Task VerifyTwoFA()
    {
        twoFAVerifying = true;
        twoFAMessage = "";

        string enteredCode = new string(twoFACode).Replace(" ", "");

        if (enteredCode.Length != 6)
        {
            twoFAMessage = "Please enter all 6 digits";
            twoFASuccess = false;
            twoFAVerifying = false;
            return;
        }

        try
        {
            // Verify the code from memory
            bool isCodeValid = unitOfWork.TwoFactorAuthService.VerifyCode(twoFAStoredCode, twoFACodeExpiry, enteredCode);
            
            if (isCodeValid)
            {
                twoFAMessage = "Code verified successfully!";
                twoFASuccess = true;
                
                // Clear the code from memory
                twoFAStoredCode = "";
                twoFACodeExpiry = DateTime.MinValue;
                
                // Proceed with login
                show2FA = false;
                twoFAFocused = false;
                StateHasChanged();
                
                // Perform the actual login
                await PerformLogin(twoFAUsername, twoFAPassword);
            }
            else
            {
                twoFAMessage = "Invalid or expired code. Please try again.";
                twoFASuccess = false;
                twoFACode = new char[] { ' ', ' ', ' ', ' ', ' ', ' ' };
                twoFAVerifying = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            twoFAMessage = $"Error verifying code: {ex.Message}";
            twoFASuccess = false;
            twoFACode = new char[] { ' ', ' ', ' ', ' ', ' ', ' ' };
            twoFAVerifying = false;
            StateHasChanged();
        }
    }

    private async Task ResendCode()
    {
        if (twoFAResendDisabled) return;

        twoFAResendDisabled = true;
        twoFAResendTimer = 60;

        try
        {
            // Generate new code in memory
            twoFAStoredCode = unitOfWork.TwoFactorAuthService.GenerateCode();
            twoFACodeExpiry = unitOfWork.TwoFactorAuthService.GetExpiryTime();

            // Send email
            bool emailSent = await unitOfWork.EmailService.SendCodeAsync(twoFAEmail, twoFAStoredCode, twoFAEmail.Split('@')[0]);

            if (emailSent)
            {
                twoFAMessage = "Code resent successfully!";
                twoFASuccess = true;
                twoFACode = new char[] { ' ', ' ', ' ', ' ', ' ', ' ' };

                // Start countdown timer
                _ = Task.Run(async () =>
                {
                    while (twoFAResendTimer > 0)
                    {
                        await Task.Delay(1000);
                        twoFAResendTimer--;
                        StateHasChanged();
                    }
                    twoFAResendDisabled = false;
                    StateHasChanged();
                });
            }
            else
            {
                twoFAMessage = "Failed to resend code. Please try again.";
                twoFASuccess = false;
                twoFAResendDisabled = false;
            }
        }
        catch (Exception ex)
        {
            twoFAMessage = $"Error resending code: {ex.Message}";
            twoFASuccess = false;
            twoFAResendDisabled = false;
        }

        StateHasChanged();
    }

    private async Task PerformLogin(string username, string password)
    {
        try
        {
            isloading = true;
            StateHasChanged();

            TokenProvider TokenProvider = new TokenProvider(unitOfWork, HttpContextAccessor);
            EmailSendStatus userToken = await TokenProvider.LoginUser(username, password);

            if (userToken.status == true)
            {
                try
                {
                    // The token is stored in session by TokenProvider (userToken.message contains the JWT token)
                   // Snackbar.Add($"📝 Token length: {userToken.message.Length} chars", Severity.Info);
                    
                    // Notify the authentication state provider with the token
                    await CustomAuthenticationStateProvider.MarkUserAsAuthenticated(userToken.message);
                 //   Snackbar.Add("🔐 Auth state notified", Severity.Info);
                    
                    // Wait for session to be persisted and auth state to update
                    await Task.Delay(500);
                    await UpdateAuthState();
                    
                  //  Snackbar.Add($"✅ Auth state: {(isAuthenticated ? "AUTHENTICATED" : "NOT AUTHENTICATED")}", Severity.Info);
                    
                    // Navigate back to the original page if provided, else Dashboard
                    NavigateToReturnUrlOrDashboard();
                }
                catch (Exception authEx)
                {
                    Snackbar.Add($"❌ Auth Error: {authEx.Message}", Severity.Error);
                    if (authEx.InnerException != null)
                    {
                        Snackbar.Add($"📋 Details: {authEx.InnerException.Message}", Severity.Error);
                    }
                    Snackbar.Add($"📋 Stack: {authEx.StackTrace?.Substring(0, Math.Min(200, authEx.StackTrace.Length))}", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add($"❌ Login Failed: {userToken.message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error during login: {ex.Message}", Severity.Error);
            Snackbar.Add($"📋 Details: {ex.InnerException?.Message}", Severity.Error);
        }
        finally
        {
            isloading = false;
            StateHasChanged();
        }
    }

    private void NavigateToReturnUrlOrDashboard()
    {
        var target = !string.IsNullOrWhiteSpace(_returnUrl) && IsLocalUrl(_returnUrl!)
            ? _returnUrl!
            : "/Dashboard";
        NavigationManager.NavigateTo(target, true);
    }

    private bool IsLocalUrl(string url)
    {
        if (string.IsNullOrEmpty(url)) return false;
        if (url.StartsWith("/")) return true;
        return false;
    }
}
