                                <div class="create-account-info-icon">✓</div>
                                <span>@LangService.T("Compare coverage options and save up to 15%","Compare opções de cobertura e poupe até 15%")</span>
                            </div>
                            <div class="create-account-info-item">
                                <div class="create-account-info-icon">✓</div>
                                <span>@LangService.T("Manage your policies in one secure place","Gerencie as suas apólices num local seguro")</span>
                            </div>
                            <div class="create-account-info-item">
                                <div class="create-account-info-icon">✓</div>
                                <span>@LangService.T("24/7 customer support and claims assistance","Suporte ao cliente 24/7 e assistência de sinistros")</span>
                            </div>
                        </div>

                        <!-- Password Requirements -->
                        <div class="registration-requirements-sidebar" style="margin-top: 24px;">
