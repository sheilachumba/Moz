    // Password requirements tracking
    private PasswordRequirements passwordRequirements = new PasswordRequirements();

    bool open_Create;
    void Open_Credit_Drawer()
    {
        user = new Users();
        passwordRequirements = new PasswordRequirements();
        open_Create = true;
    }
    void close_Create_nav()
    {
        user = new Users();
