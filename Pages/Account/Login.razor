                                    <div class="requirement-icon @(passwordRequirements.HasUppercase ? "checked" : "")">✓</div>
                                    <span>@LangService.T("One uppercase letter","Uma letra maiúscula")</span>
                                </div>
                                <div class="requirement-item">
                                    <div class="requirement-icon @(passwordRequirements.HasLowercase ? "checked" : "")">✓</div>
                                    <span>@LangService.T("One lowercase letter","Uma letra minúscula")</span>
                                </div>
                                <div class="requirement-item">
                                    <div class="requirement-icon @(passwordRequirements.HasNumber ? "checked" : "")">✓</div>
                                    <span>@LangService.T("One number","Um número")</span>
                                </div>
                                <div class="requirement-item">
                                    <div class="requirement-icon @(passwordRequirements.HasSymbol ? "checked" : "")">✓</div>
                                    <span>@LangService.T("One special character","Um carácter especial")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Side - Form -->
                    <div class="create-account-right">
                        <!-- Form -->
                        <EditForm Model="@user" OnValidSubmit="OnValidCreateAccount" id="create-form">
                            <DataAnnotationsValidator />

                            <!-- Account Type + First Name (same row on mobile too) -->
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Account Type</label>
                                    <MudSelect T="KycType" Value="user.AccountType" ValueChanged="OnAccountTypeChanged" For="@(()=>user.AccountType)" Variant="Variant.Outlined" FullWidth="true">
                                        <MudSelectItem Value="KycType.Individual">Individual</MudSelectItem>
                                        <MudSelectItem Value="KycType.Corporate">Corporate</MudSelectItem>
                                        <MudSelectItem Value="KycType.SoleProprietor">Sole Proprietor</MudSelectItem>
                                        <MudSelectItem Value="KycType.Association">Association</MudSelectItem>
                                    </MudSelect>
                                </div>
                                @if (!IsCorporateOrAssociation)
                                {
                                    <div class="form-group">
                                        <label class="form-label">First Name</label>
                                        <MudTextField @bind-Value="user.FirstName" For="@(()=>user.FirstName)" Placeholder="First Name" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"></MudTextField>
                                    </div>
                                }
                            </div>

                            <!-- Middle + Last Name Row -->
                            @if (!IsCorporateOrAssociation)
                            {
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">Middle Name</label>
                                        <MudTextField @bind-Value="user.MiddleName" For="@(()=>user.MiddleName)"  Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"></MudTextField>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Last Name</label>
                                        <MudTextField @bind-Value="user.LastName" For="@(()=>user.LastName)" Placeholder="Last Name" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"></MudTextField>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="form-row">
                                    <div class="form-group" style="width:100%">
                                        <label class="form-label">Company Name</label>
                                        <MudTextField @bind-Value="user.CompanyName" For="@(()=>user.CompanyName)" Placeholder="Company Name" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"></MudTextField>
                                    </div>
                                </div>
                            }

                            <!-- Email & Phone Row -->
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Email Address</label>
                                    <MudTextField @bind-Value="user.Email" For="@(()=>user.Email)" Placeholder="yourname@example.com" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"></MudTextField>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Phone Number</label>
                                    <MudTextField @bind-Value="user.PhoneNumber" For="@(()=>user.PhoneNumber)" Placeholder="Phone Number" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"></MudTextField>
                                </div>
                            </div>

                            <!-- Password -->
                            <div class="form-group">
                                <label class="form-label">Password</label>
                                <input @bind="user.password_hash" @bind:event="oninput" type="password" class="form-control" placeholder="Enter a strong password" style="padding: 9px 12px; font-size: 13px; border-radius: 8px; border: 1px solid #e0e0e0;" />
                                <div class="form-helper">Enter a password to check strength</div>
                            </div>

                            <!-- Confirm Password -->
                            <div class="form-group">
                                <label class="form-label">Confirm Password</label>
                                <MudTextField @bind-Value="confirmPassword" Placeholder="Re-enter your password" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" InputType="@PasswordInput" Adornment="Adornment.End" AdornmentIcon="@PasswordInputIcon" OnAdornmentClick="ButtonTestclick"></MudTextField>
                            </div>

                        </EditForm>
                    </div>
                </div>

                <!-- Footer -->
                <div class="create-account-footer" style="display:flex; gap:10px; justify-content:flex-end;">
                    <button type="button" class="create-account-button create-account-button-cancel" @onclick="close_Create_nav">
                        @LangService.T("Cancel","Cancelar")
                    </button>
                    <button type="submit" form="create-form" class="create-account-button">
                        @LangService.T("Create Account","Criar Conta")
                    </button>
                </div>
            </div>
        </DialogContent>
    </MudDialog>
</div>

@if (showForgotPassword)
{
    <!-- Custom Forgot Password Overlay -->
    <div style="position:fixed; inset:0; background:rgba(15,23,42,0.6); z-index:2000; display:flex; align-items:center; justify-content:center;">
        <div style="background:white; border-radius:24px; max-width:480px; width:100%; box-shadow:0 18px 45px rgba(15,23,42,0.35); overflow:hidden;">
            <div class="create-account-header">
                <div class="create-account-logo">
                    <img src="/images/logo.png" alt="STANDARD INSURANCE" />
                </div>
                <h1 class="create-account-title">Reset your password</h1>
                <p class="create-account-subtitle">Enter the email you use to login and we will send you a reset link.</p>
            </div>

            <div class="create-account-right" style="padding:24px;">
                <EditForm Model="@forgotModel" OnValidSubmit="SubmitForgotPassword">
                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <MudTextField @bind-Value="forgotModel.Email" For="@(() => forgotModel.Email)" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Placeholder="yourname@example.com"></MudTextField>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(forgotMessage))
                    {
                        <div style="margin-top:8px; padding:10px 12px; border-radius:8px; font-size:13px;" class="@(forgotSuccess ? "twofa-success" : "twofa-error")">
                            @forgotMessage
                        </div>
                    }

                    <div style="display:flex; gap:10px; margin-top:18px;">
                        <button type="button" class="create-account-button create-account-button-cancel" style="flex:1" @onclick="CloseForgotPassword">Cancel</button>
                        <button type="submit" class="create-account-button" style="flex:1" disabled="@forgotLoading">
                            @(forgotLoading ? "Sending..." : "Send reset link")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- 2FA Verification Modal -->
<div class="container-fluid">
    <MudDialog @bind-IsVisible="@show2FA" Options="new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Small, DisableBackdropClick = true, CloseButton = false }" Class="twofa-dialog">
        <DialogContent>
            <div class="twofa-container">
                <button type="button" class="twofa-close-btn" @onclick="@(() => { show2FA = false; twoFAFocused = false; })">
                    <MudIcon Icon="@Icons.Material.Filled.Close" />
                </button>
                <div class="twofa-header">
                    <div class="twofa-icon">🔐</div>
                    <h2 class="twofa-title">Verify Your Identity</h2>
                    <p class="twofa-subtitle">Enter the 6-digit code sent to:</p>
                    <p class="twofa-email">@twoFAEmail</p>
                </div>

                @if (!string.IsNullOrEmpty(twoFAMessage))
                {
                    <div class="@(twoFASuccess ? "twofa-success" : "twofa-error")">
                        @twoFAMessage
                    </div>
                }

                <div class="twofa-form">
                    <div class="twofa-input-group">
                        @for (int i = 0; i < 6; i++)
                        {
                            int index = i;
                            <input type="text" 
                                   @ref="codeInputRefs[index]"
                                   maxlength="1" 
                                   class="twofa-input @(twoFACode[index] != ' ' ? "filled" : "")"
                                   value="@(twoFACode[index] == ' ' ? "" : twoFACode[index].ToString())"
                                   @onchange="@((ChangeEventArgs e) => HandleCodeChange(e, index))"
                                   @onkeydown="@((KeyboardEventArgs e) => HandleCodeKeyDown(e, index))"
                                   @onkeyup="@((KeyboardEventArgs e) => HandleCodeKeyUp(e, index))"
                                   @onpaste="@((ClipboardEventArgs e) => HandlePaste(e))"
                                   placeholder="•"
                                   inputmode="numeric"
                                   autocomplete="off" />
                        }
                    </div>

                    <button type="button" class="twofa-button" @onclick="VerifyTwoFA" disabled="@(twoFAVerifying || !IsCodeComplete())">
                        @if (twoFAVerifying)
                        {
                            <span>⏳ Verifying...</span>
                        }
                        else
                        {
                            <span>✓ Verify Code</span>
                        }
                    </button>

                    <div class="twofa-resend">
                        Didn't receive the code? 
                        <span class="twofa-resend-link" @onclick="ResendCode" style="@(twoFAResendDisabled ? "opacity: 0.5; cursor: not-allowed;" : "cursor: pointer;")">
                            Resend @(twoFAResendDisabled ? $"({twoFAResendTimer}s)" : "")
                        </span>
                    </div>
                </div>
            </div>
        </DialogContent>
    </MudDialog>
</div>

@code {



    [CascadingParameter]
    public HomeLayout Layout { get; set; }

    Users user = new Users();
