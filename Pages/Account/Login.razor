    // Handle password input changes for registration form
    private async Task OnRegistrationPasswordChanged()
    {
        if (!string.IsNullOrEmpty(user.password_hash))
        {
            UpdatePasswordRequirements(user.password_hash);
        }
        else
        {
            passwordRequirements = new PasswordRequirements();
        }
        await Task.CompletedTask;
