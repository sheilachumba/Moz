    {
        if (string.IsNullOrEmpty(value))
            return sourcesOfIncome;
        return await Task.FromResult(sourcesOfIncome.Where(x => x.Code.Contains(value, StringComparison.OrdinalIgnoreCase) || 
                                                                 (x.Description != null && x.Description.Contains(value, StringComparison.OrdinalIgnoreCase))));
    }
