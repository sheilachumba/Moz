    private async Task SubmitForm()
    {
        await form.Validate();
        // Extra server-side validations
        var nuitErrors = ValidateNuit(kycData.BVN_No) ?? Enumerable.Empty<string>();
        var dobErrors = ValidateDob(dateOfBirth) ?? Enumerable.Empty<string>();
        var idExpErrors = ValidateIdExpiry(idExpiryDate) ?? Enumerable.Empty<string>();

        var allErrors = nuitErrors.Concat(dobErrors).Concat(idExpErrors).ToList();
        if (allErrors.Any())
        {
            foreach (var err in allErrors) Snackbar.Add(err, Severity.Error);
            return;
        }

        if (form.IsValid)
        {
            Layout.OpenLoading();
            try
            {
                // Map selected items to KYC model
                kycData.Contact_Type = "Individual";
                // Normalize Title before submit to keep consistency with UI values
                if (!string.IsNullOrWhiteSpace(kycData.Title))
                    kycData.Title = NormalizeTitle(kycData.Title);
                kycData.Nationality = selectedNationality?.Code;
                // State is already bound from the hardcoded dropdown
                kycData.Means_of_Identification = selectedMeansOfId?.MeansOfId;
                kycData.Date_of_Birth = dateOfBirth?.ToString("yyyy-MM-dd");
                kycData.ID_Expiry_Date = idExpiryDate?.ToString("yyyy-MM-dd");
                kycData.Approval_Status = KycStatus.Open.ToString();
                kycData.Customer_Category = "Non-Staff";
                kycData.High_Risk_Low_Risk = kycData.PEP_Status == "Yes" ? "High Risk" : "Low Risk";
                kycData.Source_of_Funds = selectedSourceOfIncome?.Code;
                kycData.Country_Region_Code = selectedResidenceCountry?.Code;
                kycData.Post_Code = selectedPostalCode?.Code;
                kycData.City = selectedPostalCode?.City;
                kycData.Stage = "KYC";
                kycData.Type = "Person";

                // Submit to ERP
                var contactNo = await UnitOfWork.ContactCardService.CreateOrUpdateContactCardAsync(kycData);

                // Get current user and update their Contact_No
                try
                {
                    var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
                    var user = authState.User;

                    if (user?.Identity?.IsAuthenticated == true)
                    {
                        var userEmail = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
                        if (!string.IsNullOrEmpty(userEmail))
                        {
                            // Get user by email and update Contact_No
                            var dbUser = await UnitOfWork.userRepository.GetByEmail(userEmail);
                            if (dbUser != null)
                            {
                                dbUser.Contact_No = contactNo;
                                await UnitOfWork.userRepository.Update(dbUser);
                                UnitOfWork.save();
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    // Log but don't fail - contact was already created in BC
                }

                Snackbar.Add($"Form submitted successfully! Contact No: {contactNo}", Severity.Success);

                // Navigate to next step
                await Task.Delay(1500);
                navigate.NavigateTo("/Individual_documents");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error submitting form: {ex.Message}", Severity.Error);
            }
            Layout.CloseLoading();
        }
    }

    // Search functions for autocomplete
    private async Task<IEnumerable<CountryRegion>> SearchCountries(string value)
    {
        if (string.IsNullOrEmpty(value))
            return countries;
        return await Task.FromResult(countries.Where(x => x.Code.Contains(value, StringComparison.OrdinalIgnoreCase) || 
                                                          x.Name.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task<IEnumerable<Religion>> SearchReligions(string value)
    {
        if (string.IsNullOrEmpty(value))
            return religions;
        return await Task.FromResult(religions.Where(x => x.Code.Contains(value, StringComparison.OrdinalIgnoreCase) || 
                                                          (x.Description != null && x.Description.Contains(value, StringComparison.OrdinalIgnoreCase))));
    }

    private async Task<IEnumerable<MeansOfIdentification>> SearchMeansOfIdentification(string value)
    {
        var filtered = meansOfIdentification
            .Where(x =>
                string.Equals(x.AccountType, "Individual", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(x.AccountType, "Person", StringComparison.OrdinalIgnoreCase))
            .ToList();

        // Fallback: if BC didn't set Account_Type, show all instead of empty
        if (filtered.Count == 0)
            filtered = meansOfIdentification.ToList();

        if (string.IsNullOrEmpty(value))
            return filtered;
        return await Task.FromResult(filtered.Where(x => x.MeansOfId.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                                                         (x.Description != null && x.Description.Contains(value, StringComparison.OrdinalIgnoreCase))));
    }

    private async Task<IEnumerable<PostalCode>> SearchPostalCodes(string value)
    {
        if (string.IsNullOrEmpty(value))
            return postalCodes;
        return await Task.FromResult(postalCodes.Where(x => x.Code.Contains(value, StringComparison.OrdinalIgnoreCase) || 
                                                            x.City.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

