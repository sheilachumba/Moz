    private async Task ClickPepFileInput(RequiredDocument document)
    {
        var fileInputId = $"pep_file_{document.No}";
        await JSRuntime.InvokeVoidAsync("eval", $"document.getElementById('{fileInputId}').click();");
    }

    private async Task OnPepFileSelected(InputFileChangeEventArgs e, RequiredDocument document)
    {
        try
        {
            var file = e.GetMultipleFiles().FirstOrDefault();
            if (file != null)
            {
                // Validate file type
                if (!file.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase))
                {
                    Snackbar.Add("Only PDF files are allowed", Severity.Error);
                    return;
                }

                // Validate file size (max 5MB)
                if (file.Size > 5 * 1024 * 1024)
                {
                    Snackbar.Add("File size must not exceed 5MB", Severity.Error);
                    return;
                }

                document.FileName = file.Name;
                document.FileData = await ReadFileAsync(file);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error selecting file: {ex.Message}", Severity.Error);
        }
    }

    private async Task<byte[]> ReadFileAsync(IBrowserFile file)
    {
        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }

    private async Task UploadPepDocument(RequiredDocument document)
    {
        if (document.FileData == null || document.FileData.Length == 0)
        {
            Snackbar.Add("Please select a file first", Severity.Warning);
            return;
        }

        try
        {
            isUploadingPepDocument = true;
            Layout?.OpenLoading();

            // Get PEP number from selected PEP
            var pepNo = selectedPepForDocuments.No;

            var spDocCode = $"PEP_{pepNo}_DOC022";
            var url = await SharePointDocuments.UploadKycDocumentAsync(
                "Pep",
                currentUserContactNo,
                spDocCode,
                document.FileData,
                document.FileName
            );

            if (!string.IsNullOrWhiteSpace(url))
            {
                document.UploadedUrl = url;
                KycUploadContext.CorporateDocumentUrlsByCode[spDocCode] = url;
            }

            // Mark as uploaded
            document.IsUploaded = true;
            document.UploadedFileName = document.FileName;
            document.FileData = null;
            document.FileName = null;

            // Refresh documents list
            await LoadPepDocuments();

            Snackbar.Add($"Document uploaded successfully!", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error uploading document: {ex.Message}", Severity.Error);
        }
        finally
        {
            isUploadingPepDocument = false;
            Layout?.CloseLoading();
        }
    }

