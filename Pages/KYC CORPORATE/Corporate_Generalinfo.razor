        }
    }
    private async Task<IEnumerable<PostalCode>> SearchPostalCodes(string value)
    {
        if (string.IsNullOrEmpty(value))
            return postalCodes;
        return await Task.FromResult(postalCodes.Where(x => x.City.Contains(value, StringComparison.OrdinalIgnoreCase) || 
                                                          x.Code.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task<IEnumerable<CountryRegion>> SearchCountries(string value)
    {
        if (string.IsNullOrEmpty(value))
            return countries;
        return await Task.FromResult(countries.Where(x => x.Name.Contains(value, StringComparison.OrdinalIgnoreCase) || 
                                                          x.Code.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task<IEnumerable<MeansOfIdentification>> SearchMeansOfIdentification(string value)
    {
        var corporateOnly = meansOfIdentification
            .Where(x =>
                string.Equals(x.AccountType, "Corporate", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(x.AccountType, "Company", StringComparison.OrdinalIgnoreCase))
            .ToList();

        // Fallback: if no AccountType provided from BC, show all instead of empty
        if (corporateOnly.Count == 0)
            corporateOnly = meansOfIdentification.ToList();
        if (string.IsNullOrEmpty(value))
            return corporateOnly;
        return await Task.FromResult(corporateOnly.Where(x => x.MeansOfId.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                                                              x.Description.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task<IEnumerable<MeansOfIdentification>> SearchIndividualMeansOfIdentification(string value)
    {
        var individualOnly = meansOfIdentification
            .Where(x => string.Equals(x.AccountType, "individual", StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (individualOnly.Count == 0)
            individualOnly = meansOfIdentification.ToList();
        if (string.IsNullOrEmpty(value))
            return individualOnly;
        return await Task.FromResult(individualOnly.Where(x => x.MeansOfId.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                                                               x.Description.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task<IEnumerable<SourceOfIncome>> SearchSourceOfIncome(string value)
    {
        if (string.IsNullOrEmpty(value))
            return sourcesOfIncome;
        return await Task.FromResult(sourcesOfIncome.Where(x => x.Description.Contains(value, StringComparison.OrdinalIgnoreCase) || 
                                                                 x.Code.Contains(value, StringComparison.OrdinalIgnoreCase)));
