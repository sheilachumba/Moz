    private async Task<IEnumerable<string>> SearchMeansOfIdentificationStrings(string value)
    {
        var filtered = meansOfIdentification
            .Where(x =>
                string.Equals(x.AccountType, "individual", StringComparison.OrdinalIgnoreCase) ||

                string.Equals(x.AccountType, "individual", StringComparison.OrdinalIgnoreCase))

            .ToList();

        if (filtered.Count == 0)
            filtered = meansOfIdentification.ToList();

        var means = filtered.Select(x => x.MeansOfId).ToList();
        if (string.IsNullOrEmpty(value))
            return means;
        return await Task.FromResult(means.Where(x => x.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private IEnumerable<string> ValidateIdExpiry(DateTime? value)
    {
        if (!RequiresIdExpiry)
            yield break;
        if (value == null)
            yield return LangService.T("ID Expiry Date is required","A data de validade do documento é obrigatória");
        else if (value.Value.Date <= DateTime.Today)
            yield return LangService.T("ID Expiry Date must be a future date","A data de validade do documento deve ser uma data futura");
    }

