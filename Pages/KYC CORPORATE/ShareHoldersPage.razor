    private async Task ClickFileInput(RequiredDocument document)
    {
        var fileInputId = $"file_{document.No}";
        await JSRuntime.InvokeVoidAsync("eval", $"document.getElementById('{fileInputId}').click();");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e, RequiredDocument document)
    {
        try
        {
            var file = e.GetMultipleFiles().FirstOrDefault();
            if (file != null)
            {
                // Validate file type
                if (!file.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase))
                {
                    Snackbar.Add("Only PDF files are allowed", Severity.Error);
                    return;
                }

                // Validate file size (max 5MB)
                if (file.Size > 5 * 1024 * 1024)
                {
                    Snackbar.Add("File size must not exceed 5MB", Severity.Error);
                    return;
                }

                document.FileName = file.Name;
                document.FileData = await ReadFileAsync(file);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error selecting file: {ex.Message}", Severity.Error);
        }
    }

    private async Task<byte[]> ReadFileAsync(IBrowserFile file)
    {
        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }

    private async Task UploadDocument(RequiredDocument document)
    {
        Layout.OpenLoading();
        if (document.FileData == null || document.FileData.Length == 0)
        {
            Snackbar.Add("Please select a file first", Severity.Warning);
            return;
        }

        try
        {
            Layout.OpenLoading();

            // Get shareholder number from selected shareholder
            var shareholderNo = selectedShareholderForDocuments.Shareholder_No;

            var spDocCode = $"SH_{shareholderNo}_DOC022";
            var url = await SharePointDocuments.UploadKycDocumentAsync(
                "Shareholders",
                currentUserContactNo,
                spDocCode,
                document.FileData,
                document.FileName
            );

            if (!string.IsNullOrWhiteSpace(url))
            {
                document.UploadedUrl = url;
                KycUploadContext.CorporateDocumentUrlsByCode[spDocCode] = url;
            }

            // Mark as uploaded
            document.IsUploaded = true;
            document.UploadedFileName = document.FileName;
            document.FileData = null;
            document.FileName = null;

            Snackbar.Add($"Document uploaded successfully!", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error uploading document: {ex.Message}", Severity.Error);
        }
        finally
        {
            Layout.CloseLoading();
        }
        Layout.CloseLoading();
    }

    private async Task SaveShareholder()
    {
        Layout.OpenLoading();
        await shareholderForm.Validate();
        if (shareholderForm.IsValid)
        {
            try
            {
                // Show loading spinner

                var shareholderDto = new ShareholderDto
                {
                    Insured_No = currentUserContactNo,
                    Name = $"{currentShareholder.Surname} {currentShareholder.FirstName}".Trim(),
                    Shareholder_Percent = currentShareholder.PercentageAllocation,
                    Means_of_Identification = currentShareholder.IdType
                };

                if (isEditMode)
                {
                    shareholderDto.Shareholder_No = int.Parse(currentShareholder.No);
                    await UnitOfWork.ShareholderService.UpdateShareholderAsync(shareholderDto);
                    successMessage = "Shareholder updated successfully!";
                }
                else
                {
                    await UnitOfWork.ShareholderService.CreateShareholderAsync(shareholderDto);
                    successMessage = "Shareholder added successfully!";
                }

                showShareholderModal = false;
                currentShareholder = new();
                await LoadShareholders();

                // Hide loading spinner

                StateHasChanged();

                // Clear success message after 3 seconds
                await Task.Delay(3000);
                successMessage = "";
                StateHasChanged();
            }
            catch (Exception ex)
            {
                // Hide loading spinner on error

                Snackbar.Add($"Error saving shareholder: {ex.Message}", Severity.Error);
            }
        }
        Layout.CloseLoading();
    }

    private async Task DeleteShareholder(ShareholderDto shareholder)
    {
        Layout.OpenLoading();
        try
        {
            await UnitOfWork.ShareholderService.DeleteShareholderAsync(shareholder.Shareholder_No, shareholder.Insured_No);
            successMessage = "Shareholder deleted successfully!";
            await LoadShareholders();
            StateHasChanged();

            await Task.Delay(3000);
            successMessage = "";
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting shareholder: {ex.Message}", Severity.Error);
        }
        Layout.CloseLoading();
    }

