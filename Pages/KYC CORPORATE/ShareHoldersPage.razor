    private async Task<IEnumerable<string>> SearchMeansOfIdentification(string value)
    {
        IEnumerable<MeansOfIdentification> filtered = meansOfIdentificationList;

        var type = currentShareholder?.ShareholderType;
        if (!string.IsNullOrWhiteSpace(type))
        {
            if (type.Equals("Company", StringComparison.OrdinalIgnoreCase))
            {
                filtered = filtered.Where(x => string.Equals(x.AccountType, "Corporate", StringComparison.OrdinalIgnoreCase));
            }
            else if (type.Equals("Individual", StringComparison.OrdinalIgnoreCase))
            {
                filtered = filtered.Where(x => string.Equals(x.AccountType, "individual", StringComparison.OrdinalIgnoreCase));
            }
        }

        if (string.IsNullOrEmpty(value))
            return filtered.Select(x => x.MeansOfId).ToList();

        return filtered
            .Where(x => x.MeansOfId.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(x => x.MeansOfId)
            .ToList();
    }

