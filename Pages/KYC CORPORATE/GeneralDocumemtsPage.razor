                </div>
                <div class="file-name">@(GetFileName("DOC128") ?? "No file chosen")</div>
                <div class="helper-text">Upload beneficial owner's NUIT (PDF only)</div>
            </div>

            <!-- Beneficial Owner – Comparative attachment -->
            <div class="document-group">
                <div class="document-title">
                    Beneficial Owner – Comparative attachment (DOC023) <span class="required">*</span>
                </div>
                <div class="file-input-wrapper">
                    <InputFile id="BeneficialOwnerComparativeFile" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC023"))" accept=".pdf" class="form-control" />
                </div>
                <div class="file-name">@(GetFileName("DOC023") ?? "No file chosen")</div>
                <div class="helper-text">Upload beneficial owner's comparative attachment (PDF only)</div>
            </div>
        </section>
    }
    </div>

    <!-- Sidebar Info -->
    <aside class="sidebar-card">
        <div class="sidebar-title">Guidance</div>
        <div class="guide-item"><MudIcon Class="guide-icon" Icon="@Icons.Material.Filled.PictureAsPdf" /> Only PDF files up to 5MB are allowed.</div>
        <div class="guide-item"><MudIcon Class="guide-icon" Icon="@Icons.Material.Filled.CheckCircle" /> Ensure all required documents are selected.</div>
        <div class="guide-item"><MudIcon Class="guide-icon" Icon="@Icons.Material.Filled.Badge" /> Names should match company records.</div>
        <MudDivider Class="my-2" />
        <div class="sidebar-title">Upload Summary</div>
        <div class="sidebar-row"><span>Selected files</span><strong>@fileData.Count</strong></div>
        <div class="sidebar-row"><span>DOC022 (Reg. Cert)</span><strong style="color:@(fileData.ContainsKey("DOC022")?"#16a34a":"#9ca3af")">@(fileData.ContainsKey("DOC022")?"✓":"—")</strong></div>
