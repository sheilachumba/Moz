        {
            <div class="sidebar-row"><span>DOC048 (Legal Rep ID)</span><strong style="color:@(fileData.ContainsKey("DOC048")?"#16a34a":"#9ca3af")">@(fileData.ContainsKey("DOC048")?"✓":"—")</strong></div>
        }
        @if (companyRepresentative == "Beneficial Owner")
        {
            <div class="sidebar-row"><span>DOC128 (BO NUIT)</span><strong style="color:@(fileData.ContainsKey("DOC128")?"#16a34a":"#9ca3af")">@(fileData.ContainsKey("DOC128")?"✓":"—")</strong></div>
            <div class="sidebar-row"><span>DOC023 (BO Comparative)</span><strong style="color:@(fileData.ContainsKey("DOC023")?"#16a34a":"#9ca3af")">@(fileData.ContainsKey("DOC023")?"✓":"—")</strong></div>
        }
    </aside>
    </div>

    <!-- Navigation / Submit -->
    <div class="action-bar">
        <div class="nav-actions">
            <MudButton Class="nav-btn nav-btn--prev" Variant="Variant.Outlined" OnClick="@(()=>navigate.NavigateTo("PepPage"))" StartIcon="@Icons.Material.Filled.ArrowBack">Previous</MudButton>
            <MudButton Class="nav-btn nav-btn--next" Variant="Variant.Filled" Color="Color.Success" OnClick="SubmitDocuments" Disabled="@isSubmitting" EndIcon="@Icons.Material.Filled.ArrowForward">@(isSubmitting ? "Uploading..." : "Next: Summary")</MudButton>
        </div>
    </div>
</div>

@code {

    [CascadingParameter]
    MainLayout Layout { get; set; }



    private Dictionary<string, string> fileNames = new();
    private Dictionary<string, byte[]> fileData = new();
    private string currentUserContactNo = "";
    private string currentCompanyInfo = "CONT00229";
    private string companyRepresentative = "";
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        Layout.OpenLoading();
        try
        {
            await GetCurrentUserContactNo();
            await LoadCompanyRepresentativeType();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error initializing page: {ex.Message}", Severity.Error);
        }
        Layout.CloseLoading();
    }

    private async Task GetCurrentUserContactNo()
    {
        Layout.OpenLoading();
        try
        {
            var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user?.Identity?.IsAuthenticated == true)
            {
                var email = user.FindFirst(ClaimTypes.Email)?.Value;
                if (!string.IsNullOrEmpty(email))
                {
                    currentUserContactNo = email;
                }
            }
        }
        catch (Exception ex)
        {
        }
        Layout.CloseLoading();
    }

    private async Task LoadCompanyRepresentativeType()
    {
        Layout.OpenLoading();
        try
        {
            var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user?.Identity?.IsAuthenticated == true)
            {
                var userEmail = user.FindFirst(ClaimTypes.Email)?.Value;
                if (!string.IsNullOrEmpty(userEmail))
                {
                    var dbUser = await UnitOfWork.userRepository.GetByEmail(userEmail);
                    if (dbUser != null && !string.IsNullOrEmpty(dbUser.CompanyRepresentative))
                    {
                        companyRepresentative = dbUser.CompanyRepresentative;
                        StateHasChanged();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            companyRepresentative = "";
        }
        Layout.CloseLoading();
    }

    private string GetFileName(string docCode)
    {
        return fileNames.ContainsKey(docCode) ? fileNames[docCode] : null;
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e, string docCode)
    {
        Layout.OpenLoading();
        try
        {
            var file = e.GetMultipleFiles().FirstOrDefault();
            if (file != null)
            {
                // Validate file type
                if (!file.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase))
                {
                    Snackbar.Add($"Only PDF files are allowed for {docCode}", Severity.Error);
                    Layout.CloseLoading();
                    return;
                }

                // Validate file size (max 5MB)
                if (file.Size > 5 * 1024 * 1024)
                {
                    Snackbar.Add($"File size must not exceed 5MB for {docCode}", Severity.Error);
                    Layout.CloseLoading();
                    return;
                }

                fileNames[docCode] = file.Name;
                fileData[docCode] = await ReadFileAsync(file);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error selecting file: {ex.Message}", Severity.Error);
        }
        Layout.CloseLoading();
    }

    private async Task<byte[]> ReadFileAsync(IBrowserFile file)
    {
        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }

    private async Task SubmitDocuments()
    {
        if (fileData.Count == 0)
        {
            Snackbar.Add("Please select at least one document to upload", Severity.Warning);
            Layout.CloseLoading();
