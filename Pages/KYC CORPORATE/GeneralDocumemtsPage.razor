        <div class="sidebar-row"><span>DOC127 (Statutes)</span><strong style="color:@(fileData.ContainsKey("DOC127")?"#16a34a":"#9ca3af")">@(fileData.ContainsKey("DOC127")?"✓":"—")</strong></div>
        <div class="sidebar-row"><span>DOC085 (Address)</span><strong style="color:@(fileData.ContainsKey("DOC085")?"#16a34a":"#9ca3af")">@(fileData.ContainsKey("DOC085")?"✓":"—")</strong></div>
        <div class="sidebar-row"><span>DOC131 (Structure)</span><strong style="color:@(fileData.ContainsKey("DOC131")?"#16a34a":"#9ca3af")">@(fileData.ContainsKey("DOC131")?"✓":"—")</strong></div>
