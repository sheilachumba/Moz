            if (failureCount == 0)
            {
                Snackbar.Add($"Successfully uploaded {successCount} document(s)!", Severity.Success);
             //   await Task.Delay(1500);
                navigate.NavigateTo("Cop_SummaryPage");
            }
            else
            {
                Snackbar.Add($"Uploaded {successCount} document(s), {failureCount} failed", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error submitting documents: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }

        Layout.CloseLoading();

    }

    private async Task UploadDocumentToBC(string customerNo, byte[] fileBytes, string fileName, string documentCode)
    {
        Layout.OpenLoading();
        var url = await SharePointDocuments.UploadKycDocumentAsync("Corporate", customerNo, documentCode, fileBytes, fileName);
        if (!string.IsNullOrWhiteSpace(url))
        {
            KycUploadContext.CorporateDocumentUrlsByCode[documentCode] = url;
        }
        Layout.CloseLoading();
    }
}
