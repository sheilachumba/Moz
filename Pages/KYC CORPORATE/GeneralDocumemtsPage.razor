@page "/GeneralDocumemtsPage"
@attribute [Authorize]
@using System.Security.Claims
@inject NavigationManager navigate
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IUnitOfWork UnitOfWork
@inject ISharePointDocumentService SharePointDocuments
@inject MOZ_UPGRADE.Services.KycUploadContext KycUploadContext
@inject AuthenticationStateProvider GetAuthenticationStateAsync
@layout MainLayout

<style>
    :root {
        --blue-900: #1F3A7F;
        --blue-800: #283A79;
        --blue-700: #2d488f;
        --blue-600: #3657a6;
        --blue-100: #e8edf9;
        --surface: #ffffff;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --radius: 12px;
        --shadow: 0 24px 60px -28px rgba(15,70,150,.20);
    }

    .kyc-page { width: 100%; min-height: 100vh; padding: 14px; background: var(--surface); }

    .header {
        background: linear-gradient(135deg, var(--blue-800), var(--blue-700));
        color: #fff;
        border-radius: var(--radius);
        padding: 12px 14px;
        box-shadow: 0 20px 40px -24px rgba(15,70,150,.30);
        margin-bottom: 12px;
        backdrop-filter: saturate(140%) blur(6px);
    }

    .header .title {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 800;
        letter-spacing: .2px;
    }

    .header .subtitle {
        margin: .35rem 0 0;
        opacity: .95;
    }

    .section {
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(148,163,184,.20);
        border-radius: var(--radius);
        padding: 14px;
        margin-bottom: 12px;
        box-shadow: 0 12px 32px -20px rgba(2,6,23,.18);
        backdrop-filter: saturate(140%) blur(6px);
    }

    .section-title { font-size: 1.05rem; font-weight: 700; color: var(--blue-700); margin-bottom: 10px; padding-bottom: 6px; border-bottom: 2px solid var(--blue-100); }

    .document-group {
        background: rgba(248,250,252,.85);
        border: 1px solid rgba(148,163,184,.18);
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 10px;
        box-shadow: 0 10px 24px -20px rgba(2,6,23,.15);
    }

    .document-title { font-weight: 700; color: var(--text); margin-bottom: 6px; }

    .required {
        color: #dc2626;
    }

    .form-control { border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; font-size: .9rem; display: block; width: 100%; }

    .form-control:focus {
        border-color: var(--blue-600);
        box-shadow: 0 0 0 3px rgba(19,97,201,.1);
        outline: none;
    }

    .action-bar { background: rgba(255,255,255,.92); border: 1px solid rgba(148,163,184,.20); border-radius: var(--radius); padding: 14px; margin-top: 12px; box-shadow: 0 12px 32px -20px rgba(2,6,23,.18); backdrop-filter: saturate(140%) blur(6px); }
    .nav-actions { margin-top: 4px; display: flex; gap: 8px; justify-content: space-between; }
    .nav-btn { border-radius: 9999px; padding: 8px 14px; font-weight: 700; }
    .nav-btn--prev { background: transparent; border: 1px solid var(--blue-600); color: var(--blue-800); box-shadow: 0 4px 10px rgba(31,58,127,.12); }
    .nav-btn--prev:hover { background: var(--blue-100); }
    .nav-btn--next { background: linear-gradient(135deg, var(--blue-800), var(--blue-600)); color: #fff; box-shadow: 0 8px 18px rgba(31,58,127,.25); }

    .helper-text {
        font-size: .85rem;
        color: var(--muted);
        margin-top: 4px;
    }

    .file-input-wrapper { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }

    .file-name {
        color: #999;
        font-size: 13px;
    }

    .content-grid { display:grid; grid-template-columns: 2fr 1fr; gap:12px; align-items:start; }
    .sidebar-card { background: rgba(255,255,255,.92); border:1px solid rgba(148,163,184,.20); border-radius: var(--radius); padding:12px; box-shadow: 0 12px 32px -20px rgba(2,6,23,.18); backdrop-filter: saturate(140%) blur(6px); }
    .sidebar-title { font-weight:700; color: var(--blue-700); margin-bottom:8px; }
    .sidebar-list { margin: 0 0 8px 16px; padding:0; color:#475569; font-size:.9rem; }
    .guide-item { display:flex; align-items:center; gap:8px; margin-bottom:6px; color:#475569; font-size:.9rem; }
    .guide-icon { color:#283A79; }
    .sidebar-row { display:flex; justify-content:space-between; margin-bottom:6px; color:#475569; }
    @@media (max-width: 600px) {
        .content-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="kyc-page">
    <!-- Header -->
    <div class="header">
        <h1 class="title">Upload Corporate Documents</h1>
        <p class="subtitle">Company: corporate account (@currentCompanyInfo)</p>
    </div>

    <!-- Step Indicator below header -->
    <StepIndicator CurrentStep="3" />

    <div class="content-grid">
    <div>
    <!-- Required Documents Section -->
    <section class="section">
        <h2 class="section-title">Required Documents</h2>

        <!-- DOC022 — Commercial Registration Certificate -->
        <div class="document-group">
            <div class="document-title">
                Commercial Registration Certificate (DOC022) <span class="required">*</span>
            </div>
            <div class="file-input-wrapper">
                <InputFile id="Doc022File" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC022"))" accept=".pdf" class="form-control" />
            </div>
            <div class="file-name">@(GetFileName("DOC022") ?? "No file chosen")</div>
            <div class="helper-text">Upload the company's commercial registration certificate (PDF only)</div>
        </div>

        <!-- DOC096 — Tax Identification Card (NUIT) -->
        <div class="document-group">
            <div class="document-title">
                Tax Identification Card (NUIT) (DOC096) <span class="required">*</span>
            </div>
            <div class="file-input-wrapper">
                <InputFile id="Doc096File" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC096"))" accept=".pdf" class="form-control" />
            </div>
            <div class="file-name">@(GetFileName("DOC096") ?? "No file chosen")</div>
            <div class="helper-text">Upload the company's NUIT document (PDF only)</div>
        </div>

        <!-- DOC126 — Minutes -->
        <div class="document-group">
            <div class="document-title">
                Minutes (DOC126) <span class="required">*</span>
            </div>
            <div class="file-input-wrapper">
                <InputFile id="Doc126File" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC126"))" accept=".pdf" class="form-control" />
            </div>
            <div class="file-name">@(GetFileName("DOC126") ?? "No file chosen")</div>
            <div class="helper-text">Upload the company's minutes (PDF only)</div>
        </div>

        <!-- DOC127 — Statutes -->
        <div class="document-group">
            <div class="document-title">
                Statutes (DOC127) <span class="required">*</span>
            </div>
            <div class="file-input-wrapper">
                <InputFile id="Doc127File" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC127"))" accept=".pdf" class="form-control" />
            </div>
            <div class="file-name">@(GetFileName("DOC127") ?? "No file chosen")</div>
            <div class="helper-text">Statutes published in the Bulletin of the Republic (PDF only)</div>
        </div>

        <!-- DOC085 — Proof of Current Address -->
        <div class="document-group">
            <div class="document-title">
                Proof of Current Address (DOC085) <span class="required">*</span>
            </div>
            <div class="file-input-wrapper">
                <InputFile id="Doc085File" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC085"))" accept=".pdf" class="form-control" />
            </div>
            <div class="file-name">@(GetFileName("DOC085") ?? "No file chosen")</div>
            <div class="helper-text">Upload proof of the company's current address (PDF only)</div>
        </div>

        <!-- Shareholder Structure -->
        <div class="document-group">
            <div class="document-title">
                Shareholder structure document (DOC131) <span class="required">*</span>
            </div>
            <div class="file-input-wrapper">
                <InputFile id="ShareholderStructureFile" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC131"))" accept=".pdf" class="form-control" />
            </div>
            <div class="file-name">@(GetFileName("DOC131") ?? "No file chosen")</div>
            <div class="helper-text">Upload shareholder structure document (PDF only)</div>
        </div>

        <!-- Audited Financials -->
        <div class="document-group">
            <div class="document-title">
                Audited financials (DOC130) (Optional)
            </div>
            <div class="file-input-wrapper">
                <InputFile id="AuditedFinancialsFile" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC130"))" accept=".pdf" class="form-control" />
            </div>
            <div class="file-name">@(GetFileName("DOC130") ?? "No file chosen")</div>
            <div class="helper-text">Upload audited financial statements (PDF only)</div>
        </div>
    </section>

    <!-- Legal Representative Documents Section - Show only if "Legal Representative" is selected -->
    @if (companyRepresentative == "Legal Representative")
    {
        <section class="section">
            <h2 class="section-title">Legal Representative Documents</h2>

            <div class="document-group">
                <div class="document-title">
                    Legal Representative – Identification document (any type) <span class="required">*</span>
                </div>
                <div class="file-input-wrapper">
                    <InputFile id="LegalRepIdFile" OnChange="@((InputFileChangeEventArgs e) => OnFileSelected(e, "DOC048"))" accept=".pdf" class="form-control" />
                </div>
                <div class="file-name">@(GetFileName("DOC048") ?? "No file chosen")</div>
                <div class="helper-text">Upload identification document for the legal representative (PDF only)</div>
            </div>
        </section>
    }

    <!-- Beneficial Owner Documents Section - Show only if "Beneficial Owner" is selected -->
