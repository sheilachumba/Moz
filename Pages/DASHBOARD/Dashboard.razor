        {
            NavigationManager.NavigateTo("/Corporate_Generalinfo");
        }
    }

    private async Task FetchKycStatusFromODataAsync(string contactNo)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(contactNo)) return;
            var baseUrl = "http://196.201.224.102:2048/BC260/ODataV4/Company('STANDARD%20INSURANCE')/ContactCard";
            var filterNo = Uri.EscapeDataString($"No eq '{contactNo}'");
            var select = Uri.EscapeDataString("No,Approval_Status");
            var url = $"{baseUrl}?$filter={filterNo}&$select={select}&$top=1";
            using var req = new HttpRequestMessage(HttpMethod.Get, url);
            var res = await Http.SendAsync(req);
            if (!res.IsSuccessStatusCode) return;
            using var stream = await res.Content.ReadAsStreamAsync();
            using var doc = await System.Text.Json.JsonDocument.ParseAsync(stream);
            if (doc.RootElement.TryGetProperty("value", out var valueArr) && valueArr.ValueKind == System.Text.Json.JsonValueKind.Array && valueArr.GetArrayLength() > 0)
            {
                var rec = valueArr[0];
                if (rec.TryGetProperty("Approval_Status", out var st))
                {
                    var s = st.GetString();
                    if (!string.IsNullOrWhiteSpace(s)) status = s;
                }
                else if (rec.TryGetProperty("Status", out var st2))
                {
                    var s2 = st2.GetString();
                    if (!string.IsNullOrWhiteSpace(s2)) status = s2;
                }
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Dashboard] OData status fetch failed: {ex.Message}");
        }
    }

    private static string ToDisplayStatus(KycStatus statusEnum)
    {
        return statusEnum switch
        {
            KycStatus.Open => "Open",
            KycStatus.Pending_Approval => "Pending Approval",
            KycStatus.Approved => "Approved",
            KycStatus.Rejected => "Rejected",
            KycStatus.Submitted => "Submitted",
            _ => "Open"
        };
    }

