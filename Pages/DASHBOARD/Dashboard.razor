    .field-label {
        font-size: 10px;
        font-weight: 700;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .field-value {
        font-size: 14px;
        font-weight: 500;
        color: #2E5090;
        line-height: 1.3;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
