    private string HeaderInitials => GetHeaderInitials();

    private string GetHeaderInitials()
    {
        if (string.IsNullOrWhiteSpace(headerName))
            return "SI";

        var parts = headerName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            var p = parts[0].Trim();
            if (p.Length >= 2) return p.Substring(0, 2).ToUpperInvariant();
            return p.ToUpperInvariant();
        }

        var first = parts[0].Trim();
        var second = parts[1].Trim();
        char c1 = first.Length > 0 ? char.ToUpperInvariant(first[0]) : 'S';
        char c2 = second.Length > 0 ? char.ToUpperInvariant(second[0]) : 'I';
        return new string(new[] { c1, c2 });
    }

    private string GetCannedSupportAnswer(string details, string type)
    {
        var text = (details ?? string.Empty).ToLowerInvariant();
        var t = (type ?? string.Empty).ToLowerInvariant();

        if (text.Contains("kyc"))
        {
            return "For KYC, please make sure all mandatory fields are completed and that your documents are clear and up to date. You can track your KYC status on the Dashboard under *KYC Status*.";
        }

        if (text.Contains("quote") || text.Contains("quotation"))
        {
            return "Quotes are created from your selected products and can be viewed under *My Quotes* or on the Insurer Quotes page. Once you confirm a quote, it is sent to the insurer in the ERP for review.";
        }

        if (text.Contains("payment") || text.Contains("pay") || text.Contains("debit note"))
        {
            return "Payments are captured against your debit notes in the *My Payments* section. After you submit a payment, you will see it reflected in your receipts once it has been processed.";
        }

        if (text.Contains("claim"))
        {
            return "Claims can be initiated from your policy details or the *My Claims* page. Make sure you provide the date of loss, description, and upload any supporting documents requested by the claims team.";
        }

        if (text.Contains("dashboard"))
        {
            return "The Dashboard gives you an overview of your KYC status, recent quotes, open claims and payments over the last 12 months so you can quickly see your position with Standard Insurance.";
        }

        if (t.Contains("feedback"))
        {
            return "Thank you for your feedback. We use client feedback to continuously improve this portal experience and our products.";
        }

        return "I have noted your request. Our team will look into it, and in the meantime you can navigate through Dashboard, Quotes, Payments and Claims using the left-hand menu for most common actions.";
    }

