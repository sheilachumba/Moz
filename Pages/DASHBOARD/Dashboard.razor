<div class="dashboard-container">
    <div class="content-wrapper">
        <div class="page-header" style="display:flex; align-items:flex-end; justify-content:space-between; gap:12px; margin:8px 0 12px 0;">
            <div>
                <div class="breadcrumb" style="font-size:12px; color:#64748b; display:flex; align-items:center; gap:6px;">
                    <span>@LangService.T("Home","Início")</span>
                    <span style="opacity:.5">/</span>
                    <span style="color:#1f2937; font-weight:600;">@LangService.T("Dashboard","Painel")</span>
                </div>
                <h1 style="margin:4px 0 0 0; font-size:22px; font-weight:800; color:#0B184E; letter-spacing:-0.015em;">@LangService.T("Dashboard","Painel")</h1>
            </div>
        </div>
        @if (status == "Approved")
        {
        <!-- KPI + Activity at Top -->
        <div class="kpi-section" style="margin-top:0; width:100%; display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:16px; margin-bottom:16px;">
            <div class="kpi-card kpi-solid" style="padding:16px; display:flex; align-items:center; gap:12px; background:#ffffff; border:1px solid #E2E8F0; border-radius:16px; box-shadow: 0 10px 24px rgba(16,24,40,0.08), 0 2px 4px rgba(16,24,40,0.06);">
                <div style="width:30px;height:30px;border-radius:8px; background:linear-gradient(135deg,#2E5090,#1F3A7F); color:white; display:flex; align-items:center; justify-content:center; font-weight:800;">K</div>
                <div style="display:flex; flex-direction:column;">
                    <div style="font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:.3px;">@LangService.T("KYC Status","Estado KYC")</div>
                    <div style="font-size:22px; line-height:1.1; font-weight:900; color:#0B184E;">@kycDisplay</div>
                </div>
            </div>
            <div class="kpi-card kpi-solid" style="padding:16px; display:flex; align-items:center; gap:12px; background:#ffffff; border:1px solid #E2E8F0; border-radius:16px; box-shadow: 0 10px 24px rgba(16,24,40,0.08), 0 2px 4px rgba(16,24,40,0.06);">
                <div style="width:30px;height:30px;border-radius:8px; background:linear-gradient(135deg,#ffb84d,#ff9900); color:white; display:flex; align-items:center; justify-content:center; font-weight:800;">Q</div>
                <div style="display:flex; flex-direction:column;">
                    <div style="font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:.3px;">@LangService.T("Quotes (30 days)","Cotações (30 dias)")</div>
                    <div style="font-size:24px; line-height:1.1; font-weight:900; color:#1f2937;">@quotesLast30</div>
                </div>
            </div>
            <div class="kpi-card kpi-solid" style="padding:16px; display:flex; align-items:center; gap:12px; background:#ffffff; border:1px solid #E2E8F0; border-radius:16px; box-shadow: 0 10px 24px rgba(16,24,40,0.08), 0 2px 4px rgba(16,24,40,0.06);">
                <div style="width:30px;height:30px;border-radius:8px; background:linear-gradient(135deg,#60a5fa,#2563eb); color:white; display:flex; align-items:center; justify-content:center; font-weight:800;">C</div>
                <div style="display:flex; flex-direction:column;">
                    <div style="font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:.3px;">@LangService.T("Claims (open)","Reclamações (abertas)")</div>
                    <div style="font-size:24px; line-height:1.1; font-weight:900; color:#1f2937;">@openClaimsCount</div>
                </div>
            </div>
            <div class="kpi-card kpi-solid" style="padding:16px; display:flex; align-items:center; gap:12px; background:#ffffff; border:1px solid #E2E8F0; border-radius:16px; box-shadow: 0 10px 24px rgba(16,24,40,0.08), 0 2px 4px rgba(16,24,40,0.06);">
                <div style="width:30px;height:30px;border-radius:8px; background:linear-gradient(135deg,#10b981,#059669); color:white; display:flex; align-items:center; justify-content:center; font-weight:800;">P</div>
                <div style="display:flex; flex-direction:column;">
                    <div style="font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:.3px;">@LangService.T("Payments (12m)","Pagamentos (12m)")</div>
                    <div style="font-size:22px; line-height:1.1; font-weight:900; color:#065f46;">@paymentsLast12m.ToString("N2")</div>
                </div>
            </div>
        </div>}

        <!-- KYC Stepper + CTA inline -->
        <div class="ios-glass" style="margin-top:0; border-radius:16px; padding:10px; margin-bottom:12px;">
            <div class="stepper-row">
                <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                @foreach (var s in kycSteps)
                {
                    <div style="display:flex; align-items:center; gap:6px;">
                        <div style="width:22px;height:22px;border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:11px; color:@(s.Index <= currentKycStep ? "white" : "#475569"); background:@(s.Index <= currentKycStep ? "#2E5090" : "#e5e7eb");">@s.Index</div>
                        <div style="font-size:11px; color:@(s.Index <= currentKycStep ? "#1f2937" : "#64748b"); font-weight:700;">@s.Label</div>
                    </div>
                    @if (s.Index < kycSteps.Count)
                    {
                        <div style="height:2px; width:28px; background:#e5e7eb;"></div>
                    }
                }
                </div>
            </div>

        </div>
        @if (status == "Approved")
        {
            <div style="padding:8px;text-align:end">
                <button class="cta-pill promo-like-btn" style="background-color:#0B184E;color:white;border-radius:8px;padding:8px" title="View Products" @onclick="GoToUnderwriterPolicies">
                <span class="cta-icon"><MudIcon Icon="@Icons.Material.Filled.Storefront" /></span>
                <span>@LangService.T("View Products", "Ver Produtos")</span>
            </button>

        </div>
        }
        <!-- Promotional Section (slim) -->
        <div class="promo-section" style="margin-top:0; padding:16px; border-radius:16px; background:#0B184E; display:grid; grid-template-columns: 1fr auto; align-items:center; gap:12px;">
            <div class="promo-content">
                <h2 class="promo-title" style="font-size:16px; margin:0 0 6px 0; font-weight:800; color:white;">@LangService.T("Get your insurance in Mozambique in minutes and save up to 15%","Obtenha o seu seguro em Moçambique em minutos e poupe até 15%")</h2>
                <p class="promo-description" style="font-size:12px; margin:0; color:gray;">@LangService.T(
                    "We assist you to choose the best insurance cover in Mozambique in line with your lifestyle and needs. Our customized benefits are tailored to help you get the best motor insurance deal in Mozambique at an affordable price. Request a callback today!",
                    "Ajudamo-lo a escolher a melhor cobertura de seguro em Moçambique de acordo com o seu estilo de vida e necessidades. Os nossos benefícios personalizados são concebidos para o ajudar a obter o melhor seguro automóvel em Moçambique a um preço acessível. Solicite um retorno de chamada hoje!")
                </p>
                 @if (status == "Open" ||status=="n/a"){

                    <MudAlert Severity="Severity.Warning" Style="font-size:12px; padding:8px;">Your KYC process hasn’t started yet. Please fill in your details to begin verification.</MudAlert>

                    <button class="promo-button" style="padding:6px 10px; font-size:12px;" @onclick="HandleKYCClick">
                        @LangService.T("Continue to KYC Form","Continuar para o formulário KYC")
                    </button>
                }
                else if (status == "Submitted")
                {
                    <MudAlert Severity="Severity.Info" Style="font-size:12px; padding:8px;">Your KYC has been submitted successfully ✅. Our team will review your details shortly.</MudAlert>

                }
                else if (status == "Pending Approval")
                {
                    <MudAlert Severity="Severity.Info" Style="font-size:12px; padding:8px;">Your KYC is under review 🔍. We’re verifying your information — this may take a short while.</MudAlert>

                }
                else if (status == "Approved")
                {
                    <MudAlert Severity="Severity.Success" Style="font-size:12px; padding:8px;">Congratulations! 🎉 Your KYC has been approved. You now have full access to all services.</MudAlert>

                }
                else if (status == "Rejected")
                {
                    <MudAlert Severity="Severity.Error" Style="font-size:12px; padding:8px;">Your KYC was not approved 😔. You can update your details and try submitting again.</MudAlert>
                    <button class="promo-button" style="padding:6px 10px; font-size:12px;" @onclick="HandleKYCClick">
                        @LangService.T("Continue to KYC Form", "Continuar para o formulário KYC")
                    </button>
                }
            </div>
            <div class="promo-image" style="display:flex; flex-direction:column; align-items:center; gap:10px;">
                <img src="Images/homeeee.png" style="height:220px; border-radius:14px; box-shadow: 0 10px 30px rgba(0,0,0,0.25);" alt="Insurance Promo" />
            </div>
        </div>
    </div>
</div>
