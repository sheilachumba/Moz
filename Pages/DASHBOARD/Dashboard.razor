                    </div>
                    <div class="form-group full">
                        <label>@LangService.T("Details","Detalhes")</label>
                        <textarea @bind="supportDetails" placeholder="@LangService.T("Enter your message or details here...","Introduza a sua mensagem ou detalhes aqui...")"></textarea>
                    </div>
                    <div class="form-buttons">
