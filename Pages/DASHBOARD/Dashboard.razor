    private int quotesLast30 = 0;
    private int openClaimsCount = 0;
    private decimal paymentsLast12m = 0m;
    private string kycDisplay => status;
    private int currentKycStep => status switch { "Open" => 1, "Submitted" => 2, "Pending Approval" => 3, "Approved" => 4, _ => 1 };
    private List<(int Index, string Label)> kycSteps = new() { (1, "Profile"), (2, "Submitted"), (3, "Review"), (4, "Approved") };
    private List<ActivityItem> recentActivities = new();

    private async Task LoadDashboardStats(string contactNo)
    {
        try
        {
            var quotes = await unitOfWork.InsurerQuoteService.GetInsurerQuotesAsync(contactNo);
            if (quotes != null && quotes.Any())
            {
                var now = DateTime.UtcNow;
                quotesLast30 = quotes.Count(q =>
                {
                    if (DateTime.TryParse(q.Document_Date, out var d))
                    {
                        var dd = d.ToUniversalTime();
                        return dd >= now.AddDays(-30);
                    }
                    return false;
                });
                // add to recent
                foreach (var q in quotes)
                {
                    if (DateTime.TryParse(q.Document_Date, out var dq))
                        recentActivities.Add(new ActivityItem { Type = "quote", Title = $"Quote {q.No} - {q.Class_Name}", Date = dq, Icon = "📄" });
                }
            }

            // Claims open count - filtered to current user like MyClaims
            var userId = await unitOfWork.Get_LoggedIn_User.UserId();
            string userContactNo = null;
            if (!string.IsNullOrWhiteSpace(userId))
            {
                var user = await unitOfWork.userRepository.GetById(userId);
                userContactNo = user?.Contact_No;
            }

            if (!string.IsNullOrWhiteSpace(userContactNo))
            {
                var contactCard = await unitOfWork.ContactCardService.GetContactCardAsync(userContactNo);
                if (contactCard != null && !string.IsNullOrWhiteSpace(contactCard.Insured_Number))
                {
                    var claims = await unitOfWork.ClaimsService.GetClaimsAsync(contactCard.Insured_Number);
                    if (claims != null)
                    {
                        openClaimsCount = claims.Count(c => string.Equals(c.Claim_Status ?? string.Empty, "Open", StringComparison.OrdinalIgnoreCase));
                        foreach (var c in claims)
                        {
                            if (DateTime.TryParse(c.Date_Notified, out var dc))
                                recentActivities.Add(new ActivityItem { Type = "claim", Title = $"Claim {c.Claim_No} - {c.Claim_Status}", Date = dc, Icon = "🧾" });
                        }
                    }
                }
            }

            // Payments (12 months)
            string insuredNo = null;
            try
            {
                var contact = currentUser?.Contact_No;
                if (!string.IsNullOrWhiteSpace(contact))
                {
                    var contactCard = await unitOfWork.ContactCardService.GetContactCardAsync(contact);
                    insuredNo = contactCard?.Insured_Number;
                }
            }
            catch { }

            if (!string.IsNullOrWhiteSpace(insuredNo))
            {
                var receipts = await unitOfWork.PostedReceiptService.GetPostedReceiptsByAccountAsync(insuredNo);
                var cutoff = DateTime.UtcNow.AddMonths(-12);
                foreach (var r in receipts ?? new List<PostedReceiptItem>())
                {
                    if (DateTime.TryParse(r.Posting_Date, out var dr))
                    {
                        if (dr.ToUniversalTime() >= cutoff)
                        {
                            paymentsLast12m += r.Total_Amount;
                        }
                        recentActivities.Add(new ActivityItem { Type = "receipt", Title = $"Receipt {r.Receipt_No} - {r.Total_Amount.ToString("N2")}", Date = dr, Icon = "💳" });
                    }
                }
            }

            // Keep only latest 8 activities
            recentActivities = recentActivities
                .OrderByDescending(a => a.Date)
                .Take(8)
                .ToList();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Dashboard] Load stats failed: {ex.Message}");
        }
        StateHasChanged();
    }

    private class ActivityItem
    {
        public string Type { get; set; }
        public string Title { get; set; }
        public DateTime Date { get; set; }
        public string Icon { get; set; }
    }
}