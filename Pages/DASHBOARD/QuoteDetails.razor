    private async Task SubmitClaim()
    {
        await claimForm.Validate();
        if (!claimFormValid || !claimForm.IsValid)
        {
            Snackbar.Add("Please complete all required claim fields (Loss Type, Loss Type Description, Date Notified, Date of Occurrence) before submitting.", Severity.Error);
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedPolicyNo))
        {
            Snackbar.Add("Missing policy number", Severity.Error);
            return;
        }

        try
        {
            claimSubmitting = true;

            var paymentInfo = await unitOfWork.DebitNoteService.GetPolicyPaymentAmountsAsync(selectedPolicyNo);
            var outstanding = paymentInfo.TaxAmount - paymentInfo.LedgerAmount;

            if (!paymentInfo.HasLedger)
            {
                await ShowPaymentAlertAndRedirect("Payment required", "You have not made any payments for this policy. Please make a payment before submitting a claim.");
                return;
            }

            if (outstanding > 0)
            {
                await ShowPaymentAlertAndRedirect("Outstanding balance", $"You still have an outstanding premium balance of {outstanding:N2}. Please finish paying your premium before submitting a claim.");
                return;
            }

            var req = new ClaimCreateRequest
            {
                Policy_No = selectedPolicyNo,
                Loss_Type = claimLossType,
                Loss_Type_Description = claimLossTypeDescription,
                Date_Notified = (claimDateNotified ?? DateTime.Today).ToString("yyyy-MM-dd"),
                Claim_Loss_Description = claimStageDescription,
                Date_of_Occurence = (claimDateOfOccurrence ?? DateTime.Today).ToString("yyyy-MM-dd")
            };

            var createdClaimNo = await unitOfWork.ClaimsService.CreateClaimAsync(req);

            try
            {
                await UploadClaimFilesToSharePointAsync(createdClaimNo);
            }
            catch
            {
                Snackbar.Add("Claim submitted but document upload to SharePoint failed.", Severity.Warning);
            }

            // Notify management by email (non-blocking for the user)
            try
            {
                var recipients = new[]
                {
                    "Sheilachumba7@gmail.com",
                    "benndora2@gmail.com",
                    "kipletingbrian285@gmail.com",
                    "emmanukiptoo98@gmail.com"
                };

                var insuredName = selectedPolicy?.Insured_Name;
                var insuredNo = selectedPolicy?.Insured_No;

                await EmailService.SendClaimSubmissionNotificationAsync(
                    recipients,
                    insuredName,
                    insuredNo,
                    selectedPolicyNo,
                    claimLossType,
                    claimLossTypeDescription,
                    claimDateOfOccurrence ?? DateTime.Today,
                    claimDateNotified ?? DateTime.Today
                );
            }
            catch
            {
                // Email failure should not block claim submission
            }

            Snackbar.Add(string.IsNullOrWhiteSpace(createdClaimNo)
                ? "Claim submitted successfully"
                : $"Claim submitted successfully. Claim No: {createdClaimNo}", Severity.Success);
            showClaimModal = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error submitting claim: {ex.Message}", Severity.Error);
        }
        finally
        {
            claimSubmitting = false;
        }
    }

    private async Task UploadClaimFilesToSharePointAsync(string? createdClaimNo)
    {
        var claimFolderKey = string.IsNullOrWhiteSpace(createdClaimNo)
            ? $"POL_{selectedPolicyNo}_{DateTime.UtcNow:yyyyMMdd_HHmmss}"
            : createdClaimNo;

        if (claimAttachments == null)
            return;

        for (var i = 0; i < claimAttachments.Count; i++)
        {
            var file = claimAttachments[i];
            if (file == null) continue;

            var docCode = $"ATT_{i + 1}";
            var bytes = await ReadBrowserFileAsync(file);
            await SharePointDocuments.UploadKycDocumentAsync("Claims", claimFolderKey, docCode, bytes, file.Name);
        }
    }

    private static async Task<byte[]> ReadBrowserFileAsync(IBrowserFile file)
    {
        const long maxFileSize = 10 * 1024 * 1024;
        await using var stream = file.OpenReadStream(maxFileSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }

    private async Task ShowPaymentAlertAndRedirect(string title, string message)
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            DisableBackdropClick = true,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true
        };

        await DialogService.ShowMessageBox(title, (MarkupString)$"<p>{message}</p>", yesText: "OK", cancelText: null, options: options);

        NavigationManager.NavigateTo("/MyPyments");
    }

