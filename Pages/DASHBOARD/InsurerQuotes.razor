    private string GetStatusClass(string status)
    {
        return status?.ToLower() switch
        {
            "released" => "status-released",
            "open" => "status-open",
            "pending" => "status-pending",
            _ => "status-pending"
        };
    }

    private string TranslateStatus(string status)
    {
        if (string.IsNullOrWhiteSpace(status)) return status;
        if (lang != "pt") return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(status);
        return status.ToLower() switch
        {
            "released" => "Emitido",
            "open" => "Aberto",
            "pending" => "Pendente",
            _ => status
        };
    }

    private string TranslateContactType(string type)
    {
        if (string.IsNullOrWhiteSpace(type)) return type;
        if (lang == "pt")
        {
            if (type.Equals("CONTACT", StringComparison.OrdinalIgnoreCase)) return "CONTACTO";
        }
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(type.ToLower());
    }

    private string TranslateInsuredType(string type)
    {
        if (string.IsNullOrWhiteSpace(type)) return type;
        if (lang == "pt")
        {
            if (type.Equals("POLICY", StringComparison.OrdinalIgnoreCase)) return "APÓLICE";
        }
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(type.ToLower());
    }

