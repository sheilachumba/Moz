    private async Task<bool> AskUserIfHasMadePaymentAsync(decimal outstandingAmount, bool hasNoLedger)
    {
        try
        {
            var title = hasNoLedger
                ? "Have you already made any payment for this policy?"
                : "Have you already paid the outstanding balance for this policy?";

            var body = hasNoLedger
                ? "<p>We cannot see any payment recorded yet for this policy. Have you already made a payment that might still be pending approval or processing?</p>"
                : $"<p>There is still an outstanding premium balance of {outstandingAmount:N2} for this policy. Have you already paid this amount and are waiting for processing?</p>";

            var options = new DialogOptions
                {
                    CloseOnEscapeKey = true,
                    DisableBackdropClick = true,
                    MaxWidth = MaxWidth.ExtraSmall,
                    FullWidth = true
                };

            var result = await DialogService.ShowMessageBox(
                title,
                (MarkupString)body,
                yesText: "Yes, I have paid",
                cancelText: "No, I have not paid",
                options: options);

            // Return true only if the user explicitly clicked "Yes, I have paid"
            return result == true;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error in AskUserIfHasMadePaymentAsync");
            return false; // Default to false in case of error
        }
    }
