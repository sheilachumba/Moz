    private void StartRenewalForm()
    {
        if (selectedPolicy == null)
        {
            renewConfirmOpen = false;
            return;
        }

        renewConfirmOpen = false;
        if (selectedPolicy != null)
        {
            var today = DateTime.Today;
            DateTime? from = null;
            DateTime? to = null;

            if (DateTime.TryParse(selectedPolicy.From_Date, out var fromParsed))
                from = fromParsed.Date;
            if (DateTime.TryParse(selectedPolicy.To_Date, out var toParsed))
                to = toParsed.Date;

            var safeStart = from ?? today;
            if (safeStart < today)
                safeStart = today;

            DateTime safeEnd;
            if (from.HasValue && to.HasValue && to.Value > from.Value)
            {
                var span = to.Value - from.Value;
                safeEnd = safeStart.Add(span);
            }
            else
            {
                safeEnd = safeStart.AddYears(1);
            }

            // Seed editable fields
            editQuoteNo = selectedPolicy.Quotation_No ?? string.Empty;
            editInsuredNo = selectedPolicy.Insured_No ?? string.Empty;
            editName = selectedPolicy.Insured_Name ?? string.Empty;
            editPolicyType = selectedPolicy.Policy_Type ?? string.Empty;
            editPolicyDescription = selectedPolicy.Policy_Description ?? string.Empty;
            editAgentName = "SYSTEM";
            editStartingDate = safeStart.ToString("yyyy-MM-dd");
            editEndingDate = safeEnd.ToString("yyyy-MM-dd");
            editDiscount = "0";
            editPremium = "0";
            editSumInsured = selectedPolicy.Total_Sum_Insured.ToString();
            editCoverType = "2";
            editPaymentMode = "BANK_";
            editPolicyNumber = selectedPolicy.No ?? string.Empty;

            RefreshRenewalPreview();
        }
        renewDialogOpen = true;
    }

    private void RefreshRenewalPreview()
    {
        // Keep preview JSON in sync with current editable fields
        decimal.TryParse(editDiscount, out var discountVal);
        decimal.TryParse(editPremium, out var premiumVal);
        decimal.TryParse(editSumInsured, out var sumInsuredVal);
        int.TryParse(editCoverType, out var coverTypeVal);

        var payload = new
        {
            quote_Noa46 = editQuoteNo ?? string.Empty,
            insured_Noa46 = editInsuredNo ?? string.Empty,
            name = editName ?? string.Empty,
            policy_Type = editPolicyType ?? string.Empty,
            policy_Description = editPolicyDescription ?? string.Empty,
            agenta39s_Name = editAgentName ?? string.Empty,
            starting_Date = editStartingDate ?? string.Empty,
            ending_Date = editEndingDate ?? string.Empty,
            discount = discountVal,
            premium = premiumVal,
            sum_Insured = sumInsuredVal,
            insurance_Cover_Typea46 = coverTypeVal,
            payment_mode = editPaymentMode ?? string.Empty,
            policy_Number = editPolicyNumber ?? string.Empty
        };

        renewalPayloadPreview = JsonSerializer.Serialize(payload, new JsonSerializerOptions { WriteIndented = true });
    }

    private async Task ConfirmRenewalAsync()
    {
        if (selectedPolicy == null)
        {
            renewDialogOpen = false;
            return;
        }

        try
        {
            Layout?.OpenLoading();

            // If user indicates they need changes, we still let them post with their edited details.
            // So we always respect the edited fields for the payload.

            // Apply edited fields back to the selected policy where relevant
            if (selectedPolicy != null)
            {
                selectedPolicy.Quotation_No = editQuoteNo;
                selectedPolicy.Insured_No = editInsuredNo;
                selectedPolicy.Insured_Name = editName;
                selectedPolicy.Policy_Type = editPolicyType;
                selectedPolicy.Policy_Description = editPolicyDescription;
                selectedPolicy.From_Date = editStartingDate;
                selectedPolicy.To_Date = editEndingDate;

                if (decimal.TryParse(editSumInsured, out var sumInsuredVal))
                {
                    selectedPolicy.Total_Sum_Insured = sumInsuredVal;
                }
            }

            var (success, errorMessage) = await UnitOfWork.PolicyCardService.SubmitPolicyRenewalAsync(selectedPolicy);
            if (success)
            {
                Snackbar.Add(LangService.T("Renewal request submitted successfully.","Pedido de renovação submetido com sucesso."), Severity.Success);
                // Refresh the policies list to show the updated status
                await OnInitializedAsync();
            }
            else
            {
                var errorText = string.IsNullOrWhiteSpace(errorMessage) 
                    ? LangService.T("Could not submit renewal request. Please try again.", "Não foi possível submeter o pedido de renovação. Tente novamente.")
                    : errorMessage;
                
                Snackbar.Add(errorText, Severity.Error);
                _logger?.LogWarning("Policy renewal failed: {ErrorMessage}", errorMessage);
            }
        }
        catch (Exception ex)
        {
            var errorMessage = $"Error submitting renewal: {ex.Message}";
            Snackbar.Add(errorMessage, Severity.Error);
            _logger?.LogError(ex, errorMessage);
        }
        finally
        {
            Layout?.CloseLoading();
            renewDialogOpen = false;
            selectedPolicy = null;
        }
    }

