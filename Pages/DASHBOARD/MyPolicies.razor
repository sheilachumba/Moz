    private async Task OnLossTypeChanged(string value)
    {
        try
        {
            claimLossType = value;
            claimLossTypeDescription = value; // Set the description to the same value as the code for now
            
            if (string.IsNullOrEmpty(value))
            {
                filteredClaimDocuments = new List<ClaimDocument>();
                return;
            }

            // Show loading state
            isDocumentsLoading = true;
            StateHasChanged();
            
            // Fetch documents for the selected category
            var documents = await UnitOfWork.ClaimsService.GetClaimDocumentsByCategoryAsync(value);
            
            // Update the documents list
            allClaimDocuments = documents;
            filteredClaimDocuments = documents;
            
            // Reset uploaded files for the new documents
            uploadedFiles = new Dictionary<string, IBrowserFile>();
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error fetching claim documents for category: {Category}", value);
            Snackbar.Add($"Error loading required documents: {ex.Message}", Severity.Error);
            filteredClaimDocuments = new List<ClaimDocument>();
        }
        finally
        {
            isDocumentsLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnFileUploaded(InputFileChangeEventArgs e, string documentNo)
    {
        try
        {
            var file = e.File;
            if (file == null) return;
            
            // Validate file size (10MB max)
            const int maxFileSize = 10 * 1024 * 1024; // 10MB
            if (file.Size > maxFileSize)
            {
                Snackbar.Add($"File '{file.Name}' exceeds 10MB limit", Severity.Error);
                return;
            }

            // Validate file type
            var allowedExtensions = new[] { ".pdf", ".jpg", ".jpeg", ".png", ".doc", ".docx" };
            var fileExtension = Path.GetExtension(file.Name).ToLowerInvariant();
            if (!allowedExtensions.Contains(fileExtension))
            {
                Snackbar.Add($"Invalid file type for '{file.Name}'. Please upload PDF, JPG, PNG, or Word documents.", Severity.Error);
                return;
            }
            
            // Store the file reference
            uploadedFiles[documentNo] = file;
            
            // Show success message
            Snackbar.Add($"Selected: {file.Name} ({(file.Size / 1024):N0} KB)", Severity.Success);
            
            // Update UI
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error handling file selection");
            Snackbar.Add("Error selecting file. Please try again.", Severity.Error);
        }
    }

    private string GetFileIcon(string fileName)
    {
        if (string.IsNullOrEmpty(fileName))
            return Icons.Material.Filled.InsertDriveFile;
            
        var extension = Path.GetExtension(fileName).ToLowerInvariant();
        return extension switch
        {
            ".pdf" => Icons.Material.Filled.PictureAsPdf,
            ".jpg" or ".jpeg" or ".png" or ".gif" => Icons.Material.Filled.Image,
            ".doc" or ".docx" => Icons.Material.Filled.Description,
            ".xls" or ".xlsx" => Icons.Material.Filled.TableChart,
            _ => Icons.Material.Filled.InsertDriveFile
        };
    }

    private async Task SubmitClaimFromMyPolicies()
    {
        try
        {
            claimSubmitting = true;
            
            // Validate form
            await claimForm.Validate();
            if (!claimFormValid || !claimForm.IsValid)
            {
                Snackbar.Add("Please complete all required fields before submitting.", Severity.Error);
                return;
            }

            if (string.IsNullOrWhiteSpace(claimSelectedPolicyNo))
            {
                Snackbar.Add("Missing policy number", Severity.Error);
                return;
            }

            var req = new ClaimCreateRequest
            {
                Policy_No = claimSelectedPolicyNo,
                Loss_Type = claimLossType,
                Loss_Type_Description = claimLossTypeDescription,
                Date_Notified = (claimDateNotified ?? DateTime.Today).ToString("yyyy-MM-dd"),
                Claim_Loss_Description = claimStageDescription,
                Date_of_Occurence = (claimDateOfOccurrence ?? DateTime.Today).ToString("yyyy-MM-dd")
            };

            var createdClaimNo = await UnitOfWork.ClaimsService.CreateClaimAsync(req);

            try
            {
                await UploadClaimFilesToSharePointAsync(createdClaimNo);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error uploading claim documents to SharePoint");
                Snackbar.Add("Claim submitted but document upload to SharePoint failed.", Severity.Warning);
            }

            Snackbar.Add(string.IsNullOrWhiteSpace(createdClaimNo)
                ? "Claim submitted successfully!"
                : $"Claim submitted successfully! Claim No: {createdClaimNo}", Severity.Success);
            showClaimModal = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error submitting claim: {ex.Message}", Severity.Error);
        }
        finally
        {
            claimSubmitting = false;
        }
    }

    private async Task UploadClaimFilesToSharePointAsync(string? createdClaimNo)
    {
        var claimFolderKey = string.IsNullOrWhiteSpace(createdClaimNo)
            ? $"POL_{claimSelectedPolicyNo}_{DateTime.UtcNow:yyyyMMdd_HHmmss}"
            : createdClaimNo;

        if (uploadedFiles != null)
        {
            foreach (var kvp in uploadedFiles)
            {
                var documentNo = kvp.Key;
                var file = kvp.Value;
                if (file == null) continue;

                var bytes = await ReadBrowserFileAsync(file);
                await SharePointDocuments.UploadKycDocumentAsync("Claims", claimFolderKey, documentNo, bytes, file.Name);
            }
        }

        if (claimAttachments != null)
        {
            for (var i = 0; i < claimAttachments.Count; i++)
            {
                var file = claimAttachments[i];
                if (file == null) continue;

                var docCode = $"ATT_{i + 1}";
                var bytes = await ReadBrowserFileAsync(file);
                await SharePointDocuments.UploadKycDocumentAsync("Claims", claimFolderKey, docCode, bytes, file.Name);
            }
        }
    }

    private static async Task<byte[]> ReadBrowserFileAsync(IBrowserFile file)
    {
        const long maxFileSize = 10 * 1024 * 1024;
        await using var stream = file.OpenReadStream(maxFileSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }

