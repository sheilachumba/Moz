@code {
    [CascadingParameter] public HomeLayout Layout { get; set; }
    private string lang = "en";
    private bool _langLoaded;
    private string T(string en, string pt) => lang == "pt" ? pt : en;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_langLoaded)
        {
            try
            {
                var stored = await JS.InvokeAsync<string>("localStorage.getItem", "site_lang");
                if (!string.IsNullOrWhiteSpace(stored))
                {
                    lang = stored;
                    StateHasChanged();
                }
            }
            catch { }
            _langLoaded = true;
        }
    }

    private async Task SetLang(string code)
    {
        lang = (code == "pt") ? "pt" : "en";
        try { await JS.InvokeVoidAsync("localStorage.setItem", "site_lang", lang); } catch { }
    }

    private void GoToLogin()
    {
        NavigationManager.NavigateTo("/login", true);
    }

    private async Task ToggleTheme()
    {
        if (Layout != null)
        {
            await Layout.ToggleTheme();
        }
    }
}
